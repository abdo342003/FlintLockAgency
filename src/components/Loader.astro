---

---

<div id="forge-loader" aria-hidden="true">
  <!-- Background forge glow -->
  <div class="loader-glow" aria-hidden="true"></div>
  <!-- Anvil silhouette -->
  <div class="loader-anvil" aria-hidden="true"></div>

  <div class="loader-inner">
    <!-- Outer ring -->
    <div class="loader-ring"></div>
    <!-- Inner ring -->
    <div class="loader-ring-inner"></div>
    <!-- Central emblem -->
    <div class="loader-emblem-wrap">
      <img src="/logo-96.png" alt="Flintlock" class="loader-emblem" />
      <div class="loader-shimmer" aria-hidden="true"></div>
    </div>
    <!-- Rising embers -->
    <div class="loader-ember" aria-hidden="true"></div>
    <div class="loader-ember loader-em2" aria-hidden="true"></div>
    <div class="loader-ember loader-em3" aria-hidden="true"></div>
    <div class="loader-ember loader-em4" aria-hidden="true"></div>
    <div class="loader-ember loader-em5" aria-hidden="true"></div>
    <!-- Sparks -->
    <div class="loader-spark" aria-hidden="true"></div>
    <div class="loader-spark loader-sp2" aria-hidden="true"></div>
    <div class="loader-spark loader-sp3" aria-hidden="true"></div>
    <div class="loader-spark loader-sp4" aria-hidden="true"></div>
    <!-- Label -->
    <p class="loader-label" id="loader-label">Forging experience…</p>
  </div>
</div>

<style is:global>
  #forge-loader {
    position: fixed;
    inset: 0;
    z-index: 2147483646;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #080a0d;
    transition: opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1), visibility 0.6s ease;
  }
  #forge-loader.loaded {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .loader-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 50% 35% at 50% 60%, rgba(255,122,26,0.1) 0%, transparent 70%),
      radial-gradient(ellipse 40% 25% at 50% 40%, rgba(25,227,240,0.05) 0%, transparent 60%);
    animation: lg-pulse 2.4s ease-in-out infinite;
  }
  @keyframes lg-pulse {
    0%, 100% { opacity: 0.5; transform: scaleY(0.95); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  .loader-anvil {
    position: absolute;
    bottom: 12%;
    width: 120px;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(255,122,26,0.06), transparent);
    border-radius: 50%;
    filter: blur(2px);
  }

  .loader-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  /* ─── Outer ring (ember) ─── */
  .loader-ring {
    position: absolute;
    width: 96px;
    height: 96px;
    border-radius: 50%;
    border: 2px solid transparent;
    border-top-color: var(--color-ember);
    border-right-color: rgba(255, 122, 26, 0.2);
    border-bottom-color: rgba(255, 122, 26, 0.05);
    box-shadow:
      0 0 18px rgba(255, 122, 26, 0.2),
      inset 0 0 12px rgba(255, 122, 26, 0.06);
    animation: l-spin 1.6s cubic-bezier(0.22, 1, 0.36, 1) infinite;
  }

  /* ─── Inner ring (cyan) ─── */
  .loader-ring-inner {
    position: absolute;
    width: 62px;
    height: 62px;
    border-radius: 50%;
    border: 1.5px solid transparent;
    border-bottom-color: var(--color-accent);
    border-left-color: rgba(25, 227, 240, 0.2);
    border-top-color: rgba(25, 227, 240, 0.05);
    box-shadow:
      0 0 14px rgba(25, 227, 240, 0.15),
      inset 0 0 8px rgba(25, 227, 240, 0.04);
    animation: l-spin 1.1s cubic-bezier(0.22, 1, 0.36, 1) infinite reverse;
  }

  /* ─── Emblem ─── */
  .loader-emblem-wrap {
    position: relative;
    width: 64px;
    height: 64px;
  }
  .loader-emblem {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 50%;
    filter: drop-shadow(0 0 8px rgba(255, 122, 26, 0.5)) drop-shadow(0 0 20px rgba(255, 122, 26, 0.2));
    animation: l-breathe 2s ease-in-out infinite;
  }
  .loader-shimmer {
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, rgba(255, 180, 70, 0.18), transparent 60%);
    animation: l-shimmer 2.2s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes l-shimmer {
    0%, 100% { opacity: 0; transform: scale(0.7); }
    50% { opacity: 1; transform: scale(1.3); }
  }

  /* ─── Ember particles ─── */
  .loader-ember {
    position: absolute;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-ember);
    top: 50%;
    left: 50%;
    box-shadow: 0 0 10px rgba(255, 122, 26, 0.8);
    animation: l-ember 1.8s ease-out infinite;
  }
  .loader-em2 { animation-delay: 0.35s; width: 4px; height: 4px; background: #ffb347; box-shadow: 0 0 8px rgba(255, 180, 70, 0.6); }
  .loader-em3 { animation-delay: 0.7s; width: 4.5px; height: 4.5px; background: #ff8c42; }
  .loader-em4 { animation-delay: 1.05s; width: 3px; height: 3px; background: #ffe066; box-shadow: 0 0 8px rgba(255, 224, 102, 0.5); }
  .loader-em5 { animation-delay: 1.4s; width: 3.5px; height: 3.5px; background: var(--color-ember); }
  @keyframes l-ember {
    0% {
      transform: translate(-50%, -50%) translateY(20px) scale(0);
      opacity: 0;
    }
    20% { opacity: 1; transform: translate(-50%, -50%) translateY(-8px) scale(1); }
    100% { transform: translate(-50%, -50%) translateY(-48px) scale(0.1); opacity: 0; }
  }

  /* ─── Flying sparks ─── */
  .loader-spark {
    position: absolute;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-ember);
    top: 50%;
    left: 50%;
    box-shadow: 0 0 10px rgba(255, 122, 26, 0.9);
    animation: l-spark 1.5s ease-out infinite;
  }
  .loader-sp2 { animation-delay: 0.4s; width: 2.5px; height: 2.5px; background: #ffb347; }
  .loader-sp3 { animation-delay: 0.8s; width: 2px; height: 2px; background: var(--color-accent); box-shadow: 0 0 8px rgba(25, 227, 240, 0.6); }
  .loader-sp4 { animation-delay: 1.2s; width: 2.5px; height: 2.5px; background: #ffe066; }
  @keyframes l-spark {
    0% {
      transform: translate(-50%, -50%) rotate(0deg) translateY(0) scale(0);
      opacity: 0;
    }
    15% { opacity: 1; transform: translate(-50%, -50%) rotate(var(--sa, 30deg)) translateY(-34px) scale(1); }
    100% { transform: translate(-50%, -50%) rotate(var(--sa, 30deg)) translateY(-60px) scale(0.1); opacity: 0; }
  }
  .loader-spark { --sa: 40deg; }
  .loader-sp2 { --sa: -50deg; }
  .loader-sp3 { --sa: 130deg; }
  .loader-sp4 { --sa: -120deg; }

  /* ─── Label ─── */
  .loader-label {
    margin-top: 90px;
    font-family: var(--font-mono, monospace);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    opacity: 0.4;
    animation: l-pulse 2.6s ease-in-out infinite;
    transition: opacity 0.35s ease;
    white-space: nowrap;
  }
  @keyframes l-pulse {
    0%, 100% { opacity: 0.25; }
    50% { opacity: 0.6; }
  }

  @keyframes l-spin {
    to { transform: rotate(360deg); }
  }
  @keyframes l-breathe {
    0%, 100% { opacity: 0.55; transform: scale(0.92); }
    50% { opacity: 1; transform: scale(1.05); }
  }

  @media (prefers-reduced-motion: reduce) {
    #forge-loader {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
    }
    #forge-loader .loader-ring,
    #forge-loader .loader-ring-inner,
    #forge-loader .loader-ember,
    #forge-loader .loader-spark,
    #forge-loader .loader-spark-path,
    #forge-loader .loader-shimmer,
    #forge-loader .loader-glow,
    #forge-loader .loader-label {
      animation: none !important;
      opacity: 0.5 !important;
    }
    #forge-loader .loader-ring {
      border-top-color: var(--color-ember);
      border-right-color: var(--color-ember);
      opacity: 0.3;
    }
    #forge-loader .loader-ring-inner {
      border-bottom-color: var(--color-accent);
      border-left-color: var(--color-accent);
      opacity: 0.3;
    }
  }
</style>

<script>
  (function () {
    var loader = document.getElementById("forge-loader");
    var label = document.getElementById("loader-label");
    if (!loader) return;

    var start = performance.now();
    var minDisplay = 2000;

    /* Label cycling */
    var phrases = [
      "Forging experience\u2026",
      "Tempering edges\u2026",
      "Stoking the forge\u2026",
      "Aligning gears\u2026",
      "Polishing surfaces\u2026",
    ];
    if (label) {
      var idx = 0;
      var cycle = setInterval(function () {
        idx = (idx + 1) % phrases.length;
        label.style.opacity = "0";
        setTimeout(function () {
          label.textContent = phrases[idx];
          label.style.opacity = "";
        }, 350);
      }, 2000);
    }

    function hideLoader() {
      var elapsed = performance.now() - start;
      var remaining = Math.max(0, minDisplay - elapsed);

      setTimeout(function () {
        if (label) clearInterval(cycle);
        loader.classList.add("loaded");
        setTimeout(function () {
          loader.style.display = "none";
        }, 650);
      }, remaining);
    }

    if (document.readyState === "complete") {
      hideLoader();
    } else {
      window.addEventListener("load", hideLoader);
      setTimeout(function () {
        if (!loader.classList.contains("loaded")) hideLoader();
      }, 4000);
    }
  })();
</script>
