---
import { useTranslations, type Lang } from "../i18n/util";
import { Icon } from "astro-icon/components";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div
  id="project-detail"
  class="fixed inset-0 z-[70] hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Project detail"
>
  <!-- Backdrop -->
  <div class="project-detail-backdrop absolute inset-0 bg-[var(--onyx)]/85 backdrop-blur-md cursor-pointer"></div>

  <!-- Panel -->
  <div class="project-detail-panel absolute inset-4 sm:inset-6 md:inset-8 flex items-start justify-center overflow-y-auto" style="pointer-events: none;">
    <div class="detail-content relative w-full max-w-3xl bg-[var(--color-surface-2)]/95 backdrop-blur-sm border border-[var(--color-border)]/30 rounded-2xl overflow-hidden shadow-2xl my-auto" style="pointer-events: auto; transform: scale(0.96); opacity: 0; transition: transform 0.4s cubic-bezier(0.22,1,0.36,1), opacity 0.35s ease;">
      <!-- Close button -->
      <button
        id="project-detail-close"
        class="absolute top-4 right-4 z-10 flex items-center justify-center w-10 h-10 rounded-full border border-[var(--color-border)]/40 bg-[var(--color-onyx)]/80 backdrop-blur-sm text-[var(--color-off-white)] cursor-pointer transition-all duration-200 hover:border-[var(--color-accent)]/40 hover:text-[var(--color-accent)] active:scale-90"
        style="touch-action: manipulation; box-shadow: 0 4px 20px rgba(0,0,0,0.3);"
        aria-label={t("portfolio.detail.close")}
      >
        <Icon name="lucide:x" class="w-5 h-5" />
      </button>

      <!-- Hero image -->
      <div class="relative w-full aspect-[16/9] sm:aspect-[21/9] overflow-hidden bg-[var(--color-onyx)]">
        <div id="detail-image-placeholder" class="absolute inset-0 flex items-center justify-center bg-[var(--color-onyx)]">
          <div class="w-16 h-16 rounded-full border-2 border-[var(--color-border)]/30 flex items-center justify-center">
            <svg class="w-8 h-8 text-[var(--color-border)]/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
        </div>
        <img id="detail-image" src="" alt="" class="absolute inset-0 w-full h-full object-cover" loading="lazy" decoding="async" />
        <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-surface-2)]/90 via-[var(--color-surface-2)]/10 to-transparent"></div>
      </div>

      <!-- Content -->
      <div id="detail-content" class="px-6 sm:px-10 pb-10 -mt-10 relative z-[1]">
        <!-- Category + Tag -->
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span id="detail-tag" class="font-mono text-[10px] tracking-[0.12em] uppercase px-3 py-1.5 rounded-lg border"></span>
          <span id="detail-category" class="font-mono text-[10px] tracking-wider uppercase text-[var(--color-text-secondary)]/50 px-2"></span>
          <span id="detail-client-wrap" class="hidden">
            <span class="font-mono text-[10px] tracking-wider uppercase text-[var(--color-text-secondary)]/40 px-2">·</span>
            <span id="detail-client" class="font-mono text-[10px] tracking-[0.08em] text-[var(--color-text-secondary)]/70"></span>
          </span>
        </div>

        <!-- Title -->
        <h2 id="detail-title" class="font-display text-2xl sm:text-3xl md:text-4xl font-extrabold tracking-[0.02em] text-[var(--color-off-white)] mb-2 leading-tight"></h2>

        <!-- Subtitle -->
        <p id="detail-subtitle" class="font-body text-base sm:text-lg text-[var(--color-text-secondary)]/70 mb-8"></p>

        <!-- Divider -->
        <div class="w-full h-px bg-gradient-to-r from-[var(--color-border)]/40 via-[var(--color-border)]/10 to-transparent mb-8"></div>

        <!-- Results metrics -->
        <div id="detail-results" class="grid grid-cols-2 sm:grid-cols-3 gap-4 mb-10"></div>

        <!-- Challenge -->
        <div class="mb-9">
          <h3 class="font-display text-sm font-bold tracking-[0.15em] uppercase mb-3 text-[var(--color-accent)]">
            {t("portfolio.detail.challenge")}
          </h3>
          <p id="detail-challenge" class="font-body text-base text-[var(--color-text-secondary)]/80 leading-relaxed"></p>
        </div>

        <!-- Solution / Our Approach -->
        <div class="mb-9">
          <h3 class="font-display text-sm font-bold tracking-[0.15em] uppercase mb-3 text-[var(--color-cta)]">
            {t("portfolio.detail.solution")}
          </h3>
          <p id="detail-solution" class="font-body text-base text-[var(--color-text-secondary)]/80 leading-relaxed"></p>
        </div>

        <!-- Features / What We Delivered -->
        <div id="detail-features-wrap" class="mb-9 hidden">
          <h3 class="font-display text-sm font-bold tracking-[0.15em] uppercase mb-4 text-[var(--color-accent)]">
            {t("portfolio.detail.features")}
          </h3>
          <div id="detail-features" class="grid grid-cols-1 sm:grid-cols-2 gap-3"></div>
        </div>

        <!-- Tech stack -->
        <div class="mb-9">
          <h3 class="font-display text-sm font-bold tracking-[0.15em] uppercase mb-4 text-[var(--color-text-secondary)]/60">
            {t("portfolio.detail.tech")}
          </h3>
          <div id="detail-tech" class="flex flex-wrap gap-2"></div>
        </div>

        <!-- Gallery -->
        <div id="detail-gallery-wrap" class="mb-9 hidden">
          <h3 class="font-display text-sm font-bold tracking-[0.15em] uppercase mb-4 text-[var(--color-text-secondary)]/60">
            {t("portfolio.detail.gallery")}
          </h3>
          <div id="detail-gallery" class="grid grid-cols-2 gap-3"></div>
        </div>

        <!-- Video -->
        <div id="detail-video-wrap" class="mb-9 hidden">
          <h3 class="font-display text-sm font-bold tracking-[0.15em] uppercase mb-4 text-[var(--color-text-secondary)]/60">
            Video
          </h3>
          <video id="detail-video" class="w-full rounded-xl border border-[var(--color-border)]/20" controls preload="none">
            <source src="" type="video/mp4" />
          </video>
        </div>

        <!-- Description -->
        <div class="mb-9">
          <p id="detail-description" class="font-body text-sm text-[var(--color-text-secondary)]/50 leading-relaxed italic"></p>
        </div>

        <!-- Divider -->
        <div class="w-full h-px bg-gradient-to-r from-[var(--color-border)]/30 via-[var(--color-border)]/10 to-transparent mb-8"></div>

        <!-- Closing CTA -->
        <div class="text-center">
          <p class="font-display text-lg sm:text-xl font-bold text-[var(--color-off-white)] mb-6">
            {t("portfolio.detail.closing")}
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
              href="https://wa.me/212706570686"
              target="_blank"
              rel="noopener"
              class="cta-forge inline-flex items-center gap-2.5 px-7 py-3.5 rounded-xl font-bold text-sm uppercase tracking-[0.12em] no-underline transition-all duration-300"
            >
              <Icon name="lucide:message-circle" class="w-4 h-4" />
              <span>{t("portfolio.detail.whatsapp")}</span>
            </a>
            <button
              id="detail-close-cta"
              class="inline-flex items-center gap-2.5 px-7 py-3.5 rounded-xl font-bold text-sm uppercase tracking-[0.12em] no-underline transition-all duration-300 cursor-pointer border border-[var(--color-accent)]/20 text-[var(--color-accent)] hover:bg-[var(--color-accent)]/10 hover:border-[var(--color-accent)]/30"
            >
              <Icon name="lucide:arrow-left" class="w-4 h-4" />
              <span>{t("portfolio.detail.close")}</span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .detail-content {
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
                opacity 0.35s ease;
  }
  .detail-content.open {
    transform: scale(1) !important;
    opacity: 1 !important;
  }
  /* Custom scrollbar for panel */
  .project-detail-panel::-webkit-scrollbar { width: 4px; }
  .project-detail-panel::-webkit-scrollbar-track { background: transparent; }
  .project-detail-panel::-webkit-scrollbar-thumb {
    background: var(--color-border);
    border-radius: 999px;
  }
  @media (prefers-reduced-motion: reduce) {
    .detail-content {
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
    .detail-content.open {
      transition: none !important;
    }
    .project-detail-backdrop {
      transition: none !important;
    }
  }
</style>

