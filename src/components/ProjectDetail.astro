        solution: { en: "Elegant warm-toned website with full-width service sections, project gallery, client testimonials, and integrated contact form with map.", fr: "Site élégant aux tons chauds avec sections de services pleine largeur, galerie projets, témoignages clients et formulaire de contact intégré avec carte." },
        results: [
          { metric: "6", label: { en: "Service categories", fr: "Catégories de services" } },
          { metric: "15+", label: { en: "Years of experience", fr: "Années d'expérience" } },
          { metric: "200+", label: { en: "Projects completed", fr: "Projets réalisés" } }
        ],
        clientName: { en: "RevetPro", fr: "RevetPro" },
        features: {
          en: ["6 service categories", "Full-width service sections", "Project gallery", "Client testimonials", "Contact form with map", "Warm premium brand design"],
          fr: ["6 catégories de services", "Sections services pleine largeur", "Galerie projets", "Témoignages clients", "Formulaire avec carte", "Design premium aux tons chauds"]
        },
        techStack: ["HTML/CSS", "JavaScript", "Responsive Design", "Gallery", "Forms"],
        image: "/img/projects/revetpro/logo.png",
        color: "#F59E0B"
      }
    ];

    const categoryColors = {
      ai: "var(--color-accent)",
      security: "var(--color-ember)",
    };

    function getAccentColor(project) {
      return categoryColors[project.category] || project.color;
    }

    let lastFocused = null;

    function escapeHtml(text) {
      const div = document.createElement("div");
      div.textContent = text;
      return div.innerHTML;
    }

    function openDetail(slug) {
      const project = projectsData.find(p => p.slug === slug);
      if (!project) return;

      lastFocused = document.activeElement;
      const accent = getAccentColor(project);

      /* Hero image */
      const img = document.getElementById("detail-image");
      const placeholder = document.getElementById("detail-image-placeholder");
      if (img && placeholder) {
        if (project.image) {
          img.src = project.image;
          img.alt = project.title[lang];
          img.classList.remove("hidden");
          placeholder.classList.add("hidden");
        } else {
          img.classList.add("hidden");
          placeholder.classList.remove("hidden");
        }
      }

      /* Tag */
      const tag = document.getElementById("detail-tag");
      if (tag) {
        tag.textContent = project.tag[lang];
        tag.style.color = accent;
        tag.style.borderColor = accent + "40";
        tag.style.background = accent + "12";
      }

      /* Category */
      const cat = document.getElementById("detail-category");
      if (cat) cat.textContent = project.category;

      /* Client name */
      const clientWrap = document.getElementById("detail-client-wrap");
      const clientEl = document.getElementById("detail-client");
      if (clientWrap && clientEl) {
        if (project.clientName) {
          clientWrap.classList.remove("hidden");
          clientEl.textContent = project.clientName[lang];
        } else {
          clientWrap.classList.add("hidden");
        }
      }

      /* Title */
      const title = document.getElementById("detail-title");
      if (title) title.textContent = project.title[lang];

      /* Subtitle */
      const subtitle = document.getElementById("detail-subtitle");
      if (subtitle) subtitle.textContent = project.subtitle[lang];

      /* Results */
      const results = document.getElementById("detail-results");
      if (results) {
        results.innerHTML = project.results.map(r => `
          <div class="flex flex-col items-center justify-center gap-1.5 p-4 rounded-xl border border-[var(--color-border)]/15 bg-[var(--color-onyx)]/50">
            <span class="font-display text-2xl sm:text-3xl font-extrabold leading-none" style="color: ${accent};">${r.metric}</span>
            <span class="font-mono text-[9px] sm:text-[10px] tracking-wider uppercase text-[var(--color-text-secondary)]/50 text-center">${escapeHtml(r.label[lang])}</span>
          </div>
        `).join("");
      }

      /* Challenge */
      const challenge = document.getElementById("detail-challenge");
      if (challenge) challenge.textContent = project.challenge[lang];

      /* Solution */
      const solution = document.getElementById("detail-solution");
      if (solution) solution.textContent = project.solution[lang];

      /* Features */
      const featuresWrap = document.getElementById("detail-features-wrap");
      const features = document.getElementById("detail-features");
      if (featuresWrap && features) {
        if (project.features && project.features[lang].length > 0) {
          featuresWrap.classList.remove("hidden");
          features.innerHTML = project.features[lang].map(f => `
            <div class="flex items-start gap-2.5 p-3 rounded-lg border border-[var(--color-border)]/10 bg-[var(--color-onyx)]/30">
              <svg class="w-4 h-4 mt-0.5 flex-shrink-0" style="color: ${accent};" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="font-body text-sm text-[var(--color-text-secondary)]/80 leading-relaxed">${escapeHtml(f)}</span>
            </div>
          `).join("");
        } else {
          featuresWrap.classList.add("hidden");
        }
      }

      /* Tech stack */
      const tech = document.getElementById("detail-tech");
      if (tech) {
        tech.innerHTML = project.techStack.map(t => `
          <span class="font-mono text-[10px] sm:text-[11px] tracking-wide uppercase px-3 py-1.5 rounded-lg border border-[var(--color-border)]/30 bg-[var(--color-onyx)]/40 text-[var(--color-text-secondary)]/60">${escapeHtml(t)}</span>
        `).join("");
      }

      /* Gallery */
      const galleryWrap = document.getElementById("detail-gallery-wrap");
      const gallery = document.getElementById("detail-gallery");
      if (galleryWrap && gallery) {
        if (project.gallery && project.gallery.length > 0) {
          galleryWrap.classList.remove("hidden");
          gallery.innerHTML = project.gallery.map(src => `
            <img src="${src}" alt="${project.title[lang]} gallery" class="w-full aspect-video object-cover rounded-lg border border-[var(--color-border)]/15" loading="lazy" decoding="async" />
          `).join("");
        } else {
          galleryWrap.classList.add("hidden");
          gallery.innerHTML = "";
        }
      }

      /* Video */
      const videoWrap = document.getElementById("detail-video-wrap");
      const video = document.getElementById("detail-video");
      if (videoWrap && video) {
        if (project.video) {
          videoWrap.classList.remove("hidden");
          video.src = project.video;
          video.poster = project.image;
        } else {
          videoWrap.classList.add("hidden");
          video.src = "";
        }
      }

      /* Description */
      const desc = document.getElementById("detail-description");
      if (desc) desc.textContent = project.description[lang];

      /* Scroll to top of content */
      const panel = detail.querySelector(".project-detail-panel");
      if (panel) panel.scrollTop = 0;

      /* Show with animation */
      detail.classList.remove("hidden");
      void detail.offsetHeight;
      content.classList.add("open");
      document.body.style.overflow = "hidden";
      closeBtn.focus();
    }

    function closeDetail() {
      content.classList.remove("open");
      document.body.style.overflow = "";
      setTimeout(() => {
        detail.classList.add("hidden");
        if (lastFocused instanceof HTMLElement) lastFocused.focus();
      }, 350);
    }

    window.addEventListener("project-open", (e) => {
      openDetail(e.detail.slug);
    });

    closeBtn.addEventListener("click", closeDetail);
    if (closeCta) closeCta.addEventListener("click", closeDetail);
    backdrop?.addEventListener("click", closeDetail);

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !detail.classList.contains("hidden")) {
        closeDetail();
      }
    });

    /* Focus trap */
    detail.addEventListener("keydown", (e) => {
      if (e.key !== "Tab") return;
      const focusable = detail.querySelectorAll('button, a, [tabindex]:not([tabindex="-1"])');
      if (focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    });
  })();
</script>
