---
---

<div id="forge-bg-static" aria-hidden="true"></div>

<canvas id="forge-bg-canvas" aria-hidden="true"></canvas>

<script>
   (function () {
     const canvas = document.getElementById("forge-bg-canvas");
     const fallback = document.getElementById("forge-bg-static");
     if (!canvas) return;

     const isTouch = "ontouchstart" in window || navigator.maxTouchPoints > 0;
     const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
     const isLowEnd = document.documentElement.getAttribute("data-lowend") === "yes";

     if (isTouch || prefersReducedMotion || isLowEnd) return;

     function syncSize() {
    const maxDim = 1000;
    const w = Math.min(canvas.clientWidth, maxDim);
    const h = Math.min(canvas.clientHeight, maxDim);
       if (canvas.width !== w || canvas.height !== h) {
         canvas.width = w;
         canvas.height = h;
       }
     }
     if (typeof ResizeObserver !== "undefined") {
       new ResizeObserver(syncSize).observe(canvas);
     }
     syncSize();

     const gl = canvas.getContext("webgl") || canvas.getContext("experimental-webgl");
     if (!gl) return;

     const vs = `attribute vec2 a_position;
varying vec2 v_texCoord;
void main() {
  v_texCoord = a_position * 0.5 + 0.5;
  gl_Position = vec4(a_position, 0.0, 1.0);
}`;

      const fs = `precision highp float;
varying vec2 v_texCoord;
uniform float u_time;
uniform vec2 u_resolution;
uniform vec2 u_mouse;
uniform float u_click;
uniform vec2 u_clickPos;

float random(vec2 st) {
    return fract(sin(dot(st.xy, vec2(12.9898,78.233))) * 43758.5453123);
}

void main() {
    vec2 uv = v_texCoord;
    vec2 mouse = u_mouse / u_resolution;
    vec2 clickP = u_clickPos / u_resolution;

    vec3 color = vec3(0.051, 0.059, 0.071);

    /* ─── Heat distortion offset (simulates hot air rising) ─── */
    float distortStrength = (1.0 - uv.y) * 0.012;
    vec2 distort = vec2(
        sin(uv.y * 12.0 + u_time * 0.6) * distortStrength,
        cos(uv.y * 10.0 + u_time * 0.5) * distortStrength * 0.5
    );
    vec2 duv = uv + distort;

    /* ─── Layer 1: Deep background stars (slow, faint) ─── */
    for(int i = 0; i < 15; i++) {
        float f = float(i);
        float t = u_time * (0.015 + random(vec2(f, 0.0)) * 0.025);
        vec2 pos = vec2(
            random(vec2(f, 1.0)),
            fract(random(vec2(f, 2.0)) - t * 0.2)
        );
        float dist = distance(duv, pos);
        float size = 0.0008 + random(vec2(f, 3.0)) * 0.0015;
        float brightness = smoothstep(size, 0.0, dist);
        vec3 starCol = vec3(0.45, 0.55, 0.65);
        color += starCol * brightness * 0.25;
    }

    /* ─── Layer 2: Main ambient particles (mid, mouse-reactive) ─── */
    for(int i = 0; i < 30; i++) {
        float f = float(i) + 30.0;
        float speed = 0.04 + random(vec2(f, 0.0)) * 0.08;
        float t = u_time * speed;

        float pullX = (duv.x - mouse.x) * 0.10;
        float pullY = (duv.y - mouse.y) * 0.05;

        vec2 pos = vec2(
            fract(random(vec2(f, 1.0)) + t * 0.08 + pullX * sin(t * 0.4 + f)),
            fract(random(vec2(f, 2.0)) - t * 0.04 + pullY * cos(t * 0.3 + f * 0.7))
        );

        /* Click burst displacement */
        vec2 burstDir = pos - clickP;
        float burstDist = length(burstDir);
        vec2 burstNorm = normalize(burstDir + 0.001);
        float burstFalloff = exp(-burstDist * 6.0);
        float burstShift = burstFalloff * u_click * 0.3;
        pos += burstNorm * burstShift;

        float dist = distance(duv, pos);
        float size = 0.0008 + random(vec2(f, 3.0)) * 0.005;
        float brightness = smoothstep(size, 0.0, dist);

        float heightFrac = 1.0 - duv.y;
        float mouseProx = 1.0 - clamp(distance(duv, mouse) * 1.8, 0.0, 1.0);
        float emberMix = heightFrac * 0.5 + mouseProx * 0.5;

        vec3 pCol = mix(
            vec3(0.1, 0.89, 0.94),
            vec3(1.0, 0.48, 0.1),
            emberMix
        );

        float twinkle = 0.6 + 0.4 * sin(u_time * 2.5 + f * 3.0);
        color += pCol * brightness * (0.35 + 0.25 * twinkle);
    }

    /* ─── Layer 3: Rising ember sparks (bottom only) ─── */
    for(int i = 0; i < 20; i++) {
        float f = float(i) + 90.0;
        float t = u_time * (0.02 + random(vec2(f, 0.0)) * 0.08);

        vec2 pos = vec2(
            random(vec2(f, 1.0)),
            fract(random(vec2(f, 2.0)) - t)
        );

        /* Ember streak: slight trail by sampling a previous position */
        vec2 prevPos = vec2(
            random(vec2(f, 1.0)) + 0.01,
            fract(random(vec2(f, 2.0)) - (t - 0.02))
        );
        float streakDist = distance(duv, mix(pos, prevPos, 0.5));
        float streakLen = 0.008;

        float heightMask = 1.0 - smoothstep(0.0, 0.7, pos.y);
        float drift = (duv.x - mouse.x) * 0.05;
        pos.x += drift;
        prevPos.x += drift;

        vec2 burstDir = pos - clickP;
        float burstDist = length(burstDir);
        vec2 burstNorm = normalize(burstDir + 0.001);
        float burstFalloff = exp(-burstDist * 6.0);
        float burstShift = burstFalloff * u_click * 0.35;
        pos += burstNorm * burstShift;

        float dist = distance(duv, pos);
        float size = 0.002 + random(vec2(f, 3.0)) * 0.01;
        float brightness = smoothstep(size, 0.0, dist) * heightMask;

        /* Streak glow */
        float streakBright = smoothstep(streakLen, 0.0, streakDist) * heightMask * 0.3;

        float fade = 1.0 - pos.y / 0.7;
        vec3 ember = mix(
            vec3(1.0, 0.55, 0.05),
            vec3(1.0, 0.2, 0.0),
            random(vec2(f, 7.0))
        );
        float twinkle = 0.6 + 0.4 * sin(u_time * 5.0 + f * 7.0);
        color += ember * (brightness + streakBright) * fade * twinkle * 0.7;
    }

    /* ─── Layer 4: Occasional fireball embers (wide, bright) ─── */
    for(int i = 0; i < 8; i++) {
        float f = float(i) + 140.0;
        float t = u_time * (0.01 + random(vec2(f, 0.0)) * 0.03);
        vec2 pos = vec2(
            random(vec2(f, 1.0)),
            fract(random(vec2(f, 2.0)) - t * 0.5)
        );
        float heightMask = 1.0 - smoothstep(0.0, 0.8, pos.y);
        float drift = (duv.x - mouse.x) * 0.08;
        pos.x += drift;
        float dist = distance(duv, pos);
        float size = 0.008 + random(vec2(f, 3.0)) * 0.015;
        float brightness = smoothstep(size, 0.0, dist) * heightMask;
        float fade = 1.0 - pos.y / 0.8;
        vec3 fire = vec3(1.0, 0.65, 0.1);
        float glow = smoothstep(size * 3.0, 0.0, dist) * 0.3;
        color += fire * (brightness * fade * 0.8 + glow);
    }

    /* ─── Pulsing forge heat glow at bottom ─── */
    float forgePulse = 0.85 + 0.15 * sin(u_time * 0.8);
    float heat = (1.0 - uv.y) * 0.18 * forgePulse;
    color += vec3(1.0, 0.25, 0.05) * heat;

    /* ─── Click ring wave ─── */
    float clickWave = 0.0;
    if (u_click > 0.0) {
        float waveDist = distance(uv, clickP);
        float wave = sin(waveDist * 60.0 - u_time * 8.0) * 0.5 + 0.5;
        clickWave = wave * exp(-waveDist * 8.0) * u_click * 0.08;
        color += vec3(1.0, 0.5, 0.1) * clickWave;
    }

    /* ─── Subtle mouse glow ring ─── */
    float mouseDist = distance(uv, mouse);
    float mouseGlow = 0.02 / (mouseDist + 0.02);
    vec3 glowCol = mix(
        vec3(0.1, 0.89, 0.94),
        vec3(1.0, 0.48, 0.1),
        uv.y
    );
    color += glowCol * mouseGlow * 0.035;

    /* ─── Warm vignette ─── */
    float vig = 1.0 - distance(uv, vec2(0.5)) * 0.4;
    color *= vig;

    gl_FragColor = vec4(color, 1.0);
}`;

     function createShader(type, src) {
       const s = gl.createShader(type);
       gl.shaderSource(s, src);
       gl.compileShader(s);
       if (!gl.getShaderParameter(s, gl.COMPILE_STATUS)) {
         console.warn("WebGL shader compile error:", gl.getShaderInfoLog(s));
         return null;
       }
       return s;
     }

     const prog = gl.createProgram();
     const vertShader = createShader(gl.VERTEX_SHADER, vs);
     const fragShader = createShader(gl.FRAGMENT_SHADER, fs);
     if (!vertShader || !fragShader) return;

     gl.attachShader(prog, vertShader);
     gl.attachShader(prog, fragShader);
     gl.linkProgram(prog);
     if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) {
       console.warn("WebGL program link error:", gl.getProgramInfoLog(prog));
       return;
     }
     gl.useProgram(prog);

     const buf = gl.createBuffer();
     gl.bindBuffer(gl.ARRAY_BUFFER, buf);
     gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1, -1, 1, -1, -1, 1, 1, 1]), gl.STATIC_DRAW);

     const pos = gl.getAttribLocation(prog, "a_position");
     gl.enableVertexAttribArray(pos);
     gl.vertexAttribPointer(pos, 2, gl.FLOAT, false, 0, 0);

     const uTime = gl.getUniformLocation(prog, "u_time");
     const uRes = gl.getUniformLocation(prog, "u_resolution");
     const uMouse = gl.getUniformLocation(prog, "u_mouse");
     const uClick = gl.getUniformLocation(prog, "u_click");
     const uClickPos = gl.getUniformLocation(prog, "u_clickPos");

     let mouse = { x: canvas.width / 2, y: canvas.height / 2 };
     let rafId = null;
     let isPaused = false;

     let clickStrength = 0;
     let clickPos = { x: canvas.width * 0.5, y: canvas.height * 0.5 };
     let clickTime = 0;

     window.addEventListener("mousemove", (event) => {
       const rect = canvas.getBoundingClientRect();
       if (rect.width && rect.height) {
         const nx = (event.clientX - rect.left) / rect.width;
         const ny = 1.0 - (event.clientY - rect.top) / rect.height;
         mouse.x = nx * canvas.width;
         mouse.y = ny * canvas.height;
       }
     });

     canvas.addEventListener("click", (event) => {
       const rect = canvas.getBoundingClientRect();
       if (rect.width && rect.height) {
         clickPos.x = (event.clientX - rect.left);
         clickPos.y = (event.clientY - rect.top);
         clickStrength = 1.0;
         clickTime = performance.now();
       }
     });

      document.addEventListener("visibilitychange", () => {
        if (document.hidden) {
          if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
          isPaused = true;
        } else if (isPaused) {
          isPaused = false;
          rafId = requestAnimationFrame(render);
        }
      });

      /* Pause rendering when hero is off-screen to save GPU */
      const heroEl = document.getElementById("hero");
      if (heroEl && typeof IntersectionObserver !== "undefined") {
        const heroObserver = new IntersectionObserver(
          ([entry]) => {
            if (entry.isIntersecting) {
              if (isPaused) { isPaused = false; rafId = requestAnimationFrame(render); }
            } else {
              if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
              isPaused = true;
            }
          },
          { rootMargin: "100px 0px" }
        );
        heroObserver.observe(heroEl);
      }

     function render(t) {
       if (typeof ResizeObserver === "undefined") syncSize();
       gl.viewport(0, 0, canvas.width, canvas.height);

       if (clickStrength > 0) {
         const elapsed = (t - clickTime) * 0.001;
         if (elapsed > 0.7) {
           clickStrength = 0;
         } else {
           clickStrength = Math.max(0, 1 - elapsed / 0.7);
         }
       }

       if (uTime) gl.uniform1f(uTime, t * 0.001);
       if (uRes) gl.uniform2f(uRes, canvas.width, canvas.height);
       if (uMouse) gl.uniform2f(uMouse, mouse.x, mouse.y);
       if (uClick) gl.uniform1f(uClick, clickStrength);
       if (uClickPos) gl.uniform2f(uClickPos, clickPos.x, canvas.height - clickPos.y);

       gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
       rafId = requestAnimationFrame(render);
     }
     rafId = requestAnimationFrame(render);
   })();
 </script>

<style is:global>
   #forge-bg-static {
     position: fixed;
     inset: 0;
     pointer-events: none;
     z-index: -1;
     background:
       radial-gradient(ellipse 80% 40% at 50% 100%, rgba(var(--color-cta-rgb), 0.08) 0%, transparent 100%),
       radial-gradient(ellipse 60% 40% at 30% 20%, rgba(var(--color-accent-rgb), 0.04) 0%, transparent 100%);
   }
   #forge-bg-canvas {
     position: fixed;
     inset: 0;
     width: 100%;
     height: 100%;
     pointer-events: none;
     z-index: -1;
       opacity: 0.25;
   }
   @media (prefers-reduced-motion: reduce) {
     #forge-bg-canvas { display: none; }
   }
</style>
