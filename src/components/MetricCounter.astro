---
interface Props {
  value: string;
  label: string;
  color?: string;
}

const { value, label, color = "var(--color-accent)" } = Astro.props;
---

<div class="metric-counter flex flex-col items-center gap-1">
  <span
    class="font-display text-2xl sm:text-3xl font-extrabold tracking-tight"
    style={`color: ${color};`}
    data-counter-value={value}
  >
    {value}
  </span>
  <span class="font-mono text-[10px] sm:text-[11px] tracking-[0.1em] uppercase text-[var(--color-text-secondary)]/60 text-center leading-tight">
    {label}
  </span>
</div>
