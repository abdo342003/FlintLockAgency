---
interface Props {
  name: string;
}

const { name } = Astro.props;
---

<span class="tech-badge inline-flex items-center gap-1 px-2 py-0.5 rounded-md font-mono text-[10px] tracking-wide uppercase border border-[var(--color-border)]/50 bg-[var(--color-surface-2)]/50 text-[var(--color-text-secondary)]/70">
  {name}
</span>
