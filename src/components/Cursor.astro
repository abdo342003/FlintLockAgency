---
---

<div id="forge-cursor" aria-hidden="true">
  <div id="cursor-trail" aria-hidden="true"></div>
  <canvas id="cursor-fire" aria-hidden="true"></canvas>
  <div id="cursor-dot"></div>
  <div id="cursor-ring"></div>
</div>

<script>
  (function () {
    const isTouch = "ontouchstart" in window || navigator.maxTouchPoints > 0;
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (isTouch || prefersReducedMotion) return;

    const dot = document.getElementById("cursor-dot");
    const ring = document.getElementById("cursor-ring");
    const trailContainer = document.getElementById("cursor-trail");
    const fireCanvas = document.getElementById("cursor-fire");
    const ctx = fireCanvas.getContext("2d");
    if (!dot || !ring || !trailContainer || !ctx) return;

    document.body.style.cursor = "none";

    function resizeCanvas() {
      fireCanvas.width = window.innerWidth;
      fireCanvas.height = window.innerHeight;
    }
    resizeCanvas();
    window.addEventListener("resize", resizeCanvas);

    /* ─── Trail dots ─── */
    const TRAIL_COUNT = 8;
    const trailDots = [];
    for (let i = 0; i < TRAIL_COUNT; i++) {
      const td = document.createElement("div");
      td.className = "trail-dot";
      trailContainer.appendChild(td);
      trailDots.push(td);
    }

    /* ─── Orbiting satellites ─── */
    const SAT_COUNT = 4;
    const satellites = [];
    for (let i = 0; i < SAT_COUNT; i++) {
      const el = document.createElement("div");
      el.className = "cursor-sat";
      trailContainer.appendChild(el);
      satellites.push({
        el,
        angle: (i / SAT_COUNT) * Math.PI * 2,
        radius: 22 + Math.random() * 6,
        speed: 1 + Math.random() * 0.6,
      });
    }

    /* ─── Fire particle system ─── */
    const particles = [];
    const MAX_PARTICLES = 120;
    const colors = [
      { r: 255, g: 200, b: 50 },   // bright yellow
      { r: 255, g: 150, b: 30 },   // orange
      { r: 255, g: 100, b: 20 },   // deep orange
      { r: 230, g: 60, b: 15 },    // red-orange
      { r: 180, g: 30, b: 10 },    // dark red
    ];

    function spawnParticle(x, y, burst) {
      if (particles.length >= MAX_PARTICLES) return;
      const angle = burst
        ? Math.random() * Math.PI * 2
        : -Math.PI / 2 + (Math.random() - 0.5) * 1.2;
      const speed = burst
        ? 2 + Math.random() * 6
        : 0.3 + Math.random() * 1.2;
      const life = burst
        ? 0.4 + Math.random() * 0.6
        : 0.6 + Math.random() * 1.0;
      const color = colors[Math.floor(Math.random() * colors.length)];
      particles.push({
        x,
        y,
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed - (burst ? 0 : 0.5 + Math.random() * 0.8),
        life,
        maxLife: life,
        size: burst ? 2 + Math.random() * 3 : 1.5 + Math.random() * 2.5,
        r: color.r,
        g: color.g,
        b: color.b,
        drift: (Math.random() - 0.5) * 0.3,
      });
    }

    function fireBurst(x, y) {
      for (let i = 0; i < 35; i++) {
        spawnParticle(x, y, true);
      }
    }

    /* ─── State ─── */
    const history = [];
    let mouseX = 0;
    let mouseY = 0;
    let prevX = 0;
    let prevY = 0;
    let ringX = 0;
    let ringY = 0;
    let ringVX = 0;
    let ringVY = 0;
    let hovering = false;
    let hasMoved = false;

    const interactive = 'a, button, [role="button"], input, select, textarea, .card-base, .magnetic, [class*="magnetic"], .clickable, .tag-badge, .process-node, .nav-link';

    dot.style.opacity = "0";
    ring.style.opacity = "0";
    trailContainer.style.opacity = "0";

    document.addEventListener("mousemove", (e) => {
      prevX = mouseX;
      prevY = mouseY;
      mouseX = e.clientX;
      mouseY = e.clientY;

      if (!hasMoved) {
        hasMoved = true;
        ringX = mouseX;
        ringY = mouseY;
        ring.style.left = ringX + "px";
        ring.style.top = ringY + "px";
        dot.style.opacity = "1";
        ring.style.opacity = "1";
        trailContainer.style.opacity = "1";
      }

      dot.style.left = mouseX + "px";
      dot.style.top = mouseY + "px";

      history.unshift({ x: mouseX, y: mouseY });
      if (history.length > TRAIL_COUNT + 1) history.pop();

      const target = document.elementFromPoint(mouseX, mouseY);
      hovering = target && target.closest(interactive);
    });

    document.addEventListener("mouseleave", () => {
      ring.style.opacity = "0";
      dot.style.opacity = "0";
      trailContainer.style.opacity = "0";
      hasMoved = false;
    });

    document.addEventListener("mouseenter", () => {
      if (hasMoved) {
        ring.style.opacity = "1";
        dot.style.opacity = "1";
        trailContainer.style.opacity = "1";
      }
    });

    function lerpColor(c1, c2, t) {
      return {
        r: Math.round(c1.r + (c2.r - c1.r) * t),
        g: Math.round(c1.g + (c2.g - c1.g) * t),
        b: Math.round(c1.b + (c2.b - c1.b) * t),
      };
    }

    function animate(now) {
      const dt = Math.min((now - (animate._last || now)) * 0.001, 0.05);
      animate._last = now;
      const speed = Math.hypot(mouseX - prevX, mouseY - prevY);

      /* ─── Spawn fire particles ─── */
      if (hasMoved && speed > 0.5) {
        const spawnCount = Math.min(Math.floor(speed * 0.4) + 1, 5);
        for (let i = 0; i < spawnCount; i++) {
          spawnParticle(
            mouseX + (Math.random() - 0.5) * 6,
            mouseY + (Math.random() - 0.5) * 6,
            false
          );
        }
      }

      /* ─── Update particles ─── */
      for (let i = particles.length - 1; i >= 0; i--) {
        const p = particles[i];
        p.x += p.vx;
        p.y += p.vy;
        p.vx += p.drift;
        p.vy += 0.15; // slight downward gravity
        p.life -= dt;
        if (p.life <= 0) {
          particles.splice(i, 1);
          continue;
        }
      }

      /* ─── Draw fire particles ─── */
      ctx.clearRect(0, 0, fireCanvas.width, fireCanvas.height);
      for (const p of particles) {
        const progress = 1 - p.life / p.maxLife;
        const alpha = (1 - progress) * 0.85;
        const size = p.size * (1 - progress * 0.6);

        const fadeColor = lerpColor(
          { r: p.r, g: p.g, b: p.b },
          { r: 80, g: 20, b: 5 },
          progress
        );

        ctx.beginPath();
        ctx.arc(p.x, p.y, size, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${fadeColor.r}, ${fadeColor.g}, ${fadeColor.b}, ${alpha})`;
        ctx.fill();

        // soft glow
        if (progress < 0.3) {
          ctx.beginPath();
          ctx.arc(p.x, p.y, size * 2.5, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${p.r}, ${p.g}, ${p.b}, ${alpha * 0.15})`;
          ctx.fill();
        }
      }

      /* ─── Trail dots (ember drift) ─── */
      for (let i = 0; i < TRAIL_COUNT; i++) {
        const pos = history[i + 1];
        if (pos) {
          const td = trailDots[i];
          const p = 1 - i / TRAIL_COUNT;
          const driftY = i * 1.2; // upward drift for ember feel
          td.style.left = pos.x + "px";
          td.style.top = (pos.y - driftY) + "px";
          td.style.opacity = p * 0.55;
          td.style.transform = `translate(-50%, -50%) scale(${0.2 + p * 0.8})`;
          td.style.backgroundColor = hovering
            ? "var(--color-accent)"
            : i < 3
              ? "rgba(255, 200, 50, 1)"
              : i < 6
                ? "rgba(255, 120, 30, 1)"
                : "rgba(180, 40, 10, 1)";
        }
      }

      /* ─── Ring spring physics ─── */
      const dx = mouseX - ringX;
      const dy = mouseY - ringY;
      ringVX += dx * 0.1;
      ringVY += dy * 0.1;
      ringVX *= 0.72;
      ringVY *= 0.72;
      ringX += ringVX;
      ringY += ringVY;
      ring.style.left = ringX + "px";
      ring.style.top = ringY + "px";

      /* ─── Orbiting satellites ─── */
      const satBaseRadius = hovering ? 34 : 22;
      for (const sat of satellites) {
        sat.angle += sat.speed * dt;
        const wobble = 1 + Math.sin(sat.angle * 2 + satellites.indexOf(sat)) * 0.12;
        const r = satBaseRadius * wobble;
        const sx = ringX + Math.cos(sat.angle) * r;
        const sy = ringY + Math.sin(sat.angle) * r;
        sat.el.style.left = sx + "px";
        sat.el.style.top = sy + "px";
        sat.el.style.opacity = hovering ? "0.8" : "0.5";
        sat.el.style.backgroundColor = hovering
          ? "var(--color-accent)"
          : "var(--color-ember)";
        const satScale = 0.6 + Math.sin(sat.angle * 3 + sat.speed) * 0.2;
        sat.el.style.transform = `translate(-50%, -50%) scale(${satScale})`;
      }

      /* ─── Hover state ─── */
      if (hovering) {
        ring.style.width = "48px";
        ring.style.height = "48px";
        ring.style.borderColor = "var(--color-ember)";
        ring.style.borderWidth = "2px";
        ring.style.backgroundColor = "rgba(255, 122, 26, 0.06)";
        ring.style.boxShadow = "0 0 25px rgba(255, 150, 30, 0.2), 0 0 50px rgba(255, 100, 20, 0.1)";
        dot.style.width = "4px";
        dot.style.height = "4px";
        dot.style.backgroundColor = "var(--color-ember)";
      } else {
        ring.style.width = "32px";
        ring.style.height = "32px";
        ring.style.borderColor = "rgba(255, 122, 26, 0.35)";
        ring.style.borderWidth = "1px";
        ring.style.backgroundColor = "transparent";
        ring.style.boxShadow = "0 0 12px rgba(255, 122, 26, 0.08), 0 0 30px rgba(255, 80, 10, 0.04)";
        dot.style.width = "8px";
        dot.style.height = "8px";
        dot.style.backgroundColor = "var(--color-ember)";
      }

      requestAnimationFrame(animate);
    }

    document.addEventListener("mousedown", () => {
      ring.classList.add("spark-burst");
      setTimeout(() => ring.classList.remove("spark-burst"), 400);

      for (const sat of satellites) {
        sat.radius *= 1.5;
        setTimeout(() => { sat.radius = 22 + Math.random() * 6; }, 200);
      }

      fireBurst(mouseX, mouseY);
    });

    document.addEventListener("visibilitychange", () => {
      const v = document.hidden ? "0" : "1";
      ring.style.opacity = v;
      dot.style.opacity = v;
      trailContainer.style.opacity = v;
    });

    requestAnimationFrame(animate);
  })();
</script>

<style>
  #forge-cursor {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 2147483647;
  }
  #cursor-fire {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }
  #cursor-trail {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 2;
  }
  .trail-dot {
    position: fixed;
    top: 0;
    left: 0;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    pointer-events: none;
    will-change: transform, opacity;
  }
  .cursor-sat {
    position: fixed;
    top: 0;
    left: 0;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    pointer-events: none;
    will-change: transform, opacity;
    box-shadow: 0 0 6px currentColor;
  }
  #cursor-dot {
    position: fixed;
    top: 0;
    left: 0;
    width: 8px;
    height: 8px;
    background-color: var(--color-ember);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;
    transition: width 0.3s ease, height 0.3s ease, background-color 0.3s ease;
    box-shadow: 0 0 8px rgba(255, 122, 26, 0.4);
  }
  #cursor-ring {
    position: fixed;
    top: 0;
    left: 0;
    width: 32px;
    height: 32px;
    border: 1px solid rgba(255, 122, 26, 0.35);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;
    transition:
      width 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      height 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.3s ease,
      border-width 0.3s ease,
      background-color 0.3s ease,
      box-shadow 0.3s ease;
    animation: fire-breath 2s ease-in-out infinite;
  }
  @keyframes spark {
    0% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 1;
    }
    50% {
      box-shadow: 0 0 40px rgba(255, 122, 26, 0.25);
    }
    100% {
      transform: translate(-50%, -50%) scale(2.5);
      opacity: 0;
    }
  }
  @keyframes fire-breath {
    0%, 100% {
      box-shadow: 0 0 10px rgba(255, 122, 26, 0.08), 0 0 30px rgba(255, 80, 10, 0.03);
    }
    50% {
      box-shadow: 0 0 16px rgba(255, 150, 30, 0.12), 0 0 40px rgba(255, 100, 20, 0.06);
    }
  }
  .spark-burst {
    animation: spark 0.4s ease-out forwards;
  }
  @media (pointer: coarse) {
    #forge-cursor, #cursor-fire, #cursor-trail { display: none !important; }
  }
</style>
