---
import { useTranslations, type Lang } from "../i18n/util";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const portfolioHref = lang === "fr" ? "/fr/portfolio" : "/portfolio";
---

<section id="proof" class="py-[var(--stack-lg)] px-[var(--margin-mobile)] md:px-[var(--margin-desktop)] relative">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background: radial-gradient(ellipse 50% 30% at 50% 20%, rgba(25,227,240,0.03) 0%, transparent 70%);"></div>
  <div class="mx-auto relative" style="max-width: var(--container-max);">
    <div class="reveal">
      <p class="section-kicker">{t("proof.kicker")}</p>
      <h2 class="section-title mb-6">{t("proof.block1.title")}</h2>
      <p class="text-base md:text-lg text-[var(--color-text-secondary)] leading-relaxed mb-16 border-l-2 border-[var(--color-accent)]/30 pl-5">
        {t("proof.section.intro")}
      </p>
    </div>

    <!-- Badges + CTA -->
    <div class="border-t border-[var(--color-border)] pt-6 reveal">
      <div class="flex flex-wrap items-center justify-center gap-2 sm:gap-3">
        <span class="font-mono text-[9px] sm:text-[10px] tracking-widest uppercase text-[var(--color-text-secondary)]/40">{t("proof.recognition.label")}</span>
        <span class="h-3 w-px bg-[var(--color-border)] hidden sm:inline"></span>
        <span class="tag-badge tag-badge-cyan">{t("proof.recognition.emsi")}</span>
        <span class="tag-badge tag-badge-cyan">{t("proof.recognition.hackdays")}</span>
        <span class="tag-badge tag-badge-cyan">{t("proof.recognition.whitehat")}</span>
      </div>
      <div class="flex justify-center mt-8">
        <a href={portfolioHref} class="ignition-cta inline-flex items-center gap-2 px-6 py-3 no-underline font-bold text-xs uppercase tracking-[0.12em] rounded-[var(--radius-md)]" style="background: var(--color-cta); color: #000;">
          {t("proof.cta")}
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>

    <!-- Testimonials -->
    <div class="mt-20">
      <p class="section-kicker">{t("testimonials.kicker")}</p>
      <h2 class="section-title mb-4">{t("testimonials.title")}</h2>
      <div class="flex items-center gap-2 mb-10 reveal">
        <div class="flex gap-0.5">
          {[1,2,3,4,5].map(() => (
            <svg class="w-4 h-4 text-[var(--color-cta)]" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          ))}
        </div>
        <span class="font-mono text-sm text-[var(--color-text-secondary)]">{t("testimonials.rating")}</span>
        <span class="font-mono text-xs text-[var(--color-text-secondary)]/50">({t("testimonials.count")} {t("stats.projects.label")})</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-[var(--gutter)]">
        {[1, 2, 3].map((i) => (
          <div class="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-2)] p-6 md:p-7 flex flex-col shadow-[inset_1px_1px_0px_0px_rgba(25,227,240,0.08)] reveal" style={`transition-delay: ${0.08 * i}s`}>
            <div class="flex gap-0.5 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-3.5 h-3.5 text-[var(--color-cta)]" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed italic mb-4">"{t(`testimonials.${i}.quote`)}"</p>
            <div class="mt-auto pt-4 border-t border-[var(--color-border)]">
              <p class="font-bold text-sm text-[var(--color-text-primary)]">{t(`testimonials.${i}.name`)}</p>
              <p class="text-xs text-[var(--color-text-secondary)]/60">{t(`testimonials.${i}.role`)}</p>
              <span class="tag-badge mt-2 text-[9px]">{t(`testimonials.${i}.project`)}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>


