---
import { useTranslations, type Lang } from "../i18n/util";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="py-[var(--stack-lg)] px-[var(--margin-mobile)] md:px-[var(--margin-desktop)] relative section-glow-ember">
  <div class="mx-auto relative" style="max-width: var(--container-max);">
    <div class="reveal">
      <p class="section-kicker">{t("solution.kicker")}</p>
      <h2 class="section-title">{t("solution.title")}</h2>
      <p class="text-base md:text-lg text-[var(--color-text-secondary)] leading-relaxed mb-6">
        {t("solution.desc")}
      </p>
      <div class="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-2)] p-6 md:p-7 mb-8 shadow-[inset_1px_1px_0px_0px_rgba(255,122,26,0.08)] hover:shadow-[0_0_12px_rgba(255,122,26,0.08)] transition-all duration-300 reveal" style="border-left: 2px solid var(--color-cta);">
        <p class="text-sm md:text-base text-[var(--color-off-white)]/90 leading-relaxed">
          <span class="text-[var(--color-cta)] font-bold">{t("solution.security_tag")}</span> {t("solution.security_desc")}
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-3 mb-6">
        <a href="#services" class="text-sm text-[var(--color-text-secondary)]/70 hover:text-[var(--color-accent)] no-underline transition-colors">{lang === "fr" ? "Découvrez nos services" : "Explore our services"} &rarr;</a>
      </div>
      <a href="https://wa.me/212706570686" target="_blank" rel="noopener" class="cta-forge inline-flex items-center gap-2 px-8 py-4 rounded-[var(--radius-md)] text-black font-bold text-sm uppercase tracking-widest no-underline transition-all duration-300 magnetic">
        {t("solution.cta")}
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>
