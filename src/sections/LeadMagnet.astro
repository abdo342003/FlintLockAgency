---
import { useTranslations, type Lang } from "../i18n/util";
import { Icon } from "astro-icon/components";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="leadmagnet" class="py-[var(--stack-lg)] px-[var(--margin-mobile)] md:px-[var(--margin-desktop)] relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background: radial-gradient(ellipse 50% 40% at 20% 50%, rgba(25,227,240,0.04) 0%, transparent 70%);"></div>
  <div class="mx-auto relative" style="max-width: var(--container-max);">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Content -->
      <div class="reveal">
        <p class="section-kicker">{t("leadmag.kicker")}</p>
        <h2 class="section-title mb-4">{t("leadmag.title")}</h2>
        <p class="text-base md:text-lg text-[var(--color-text-secondary)] leading-relaxed mb-8">
          {t("leadmag.desc")}
        </p>
        <div id="leadmag-form" class="flex flex-col sm:flex-row gap-3">
          <label for="leadmag-email" class="sr-only">{t("leadmag.email.placeholder")}</label>
          <input
            type="email"
            id="leadmag-email"
            placeholder={t("leadmag.email.placeholder")}
            class="flex-1 bg-[var(--color-onyx)]/60 border border-[var(--color-border)] border-l-2 border-l-[var(--color-accent)]/50 px-4 py-3 text-sm text-[var(--color-off-white)] placeholder-[var(--color-off-white)]/50 rounded-[var(--radius-md)] input-forge"
            required
          />
          <button
            id="leadmag-submit"
            class="cta-forge inline-flex items-center justify-center gap-2 px-6 py-3 rounded-[var(--radius-md)] text-black font-bold text-sm uppercase tracking-widest transition-all duration-300 cursor-pointer whitespace-nowrap"
            data-cta-label={t("leadmag.cta")}
          >
            <Icon name="lucide:download" class="w-4 h-4" />
            <span>{t("leadmag.cta")}</span>
          </button>
        </div>
        <p id="leadmag-status" class="hidden font-mono text-xs mt-3" role="status" aria-live="polite" data-i18n-invalid={t("leadmag.error.invalid")} data-i18n-server-error={t("leadmag.error.server")} data-i18n-success={t("leadmag.success.download")}></p>
        <p class="font-mono text-[10px] text-[var(--color-text-secondary)]/40 mt-3">{t("leadmag.note")}</p>
      </div>

      <!-- Right: Ebook visual -->
      <div class="relative flex items-center justify-center reveal" style="transition-delay: 0.15s;">
        <div class="relative w-56 h-72 md:w-64 md:h-80">
          <!-- Book cover -->
          <div class="absolute inset-0 rounded-lg bg-gradient-to-br from-[var(--color-accent)]/10 to-[var(--color-cta)]/10 border border-[var(--color-accent)]/20 shadow-[0_0_40px_rgba(25,227,240,0.1)] rotate-[-3deg] transition-transform duration-500 hover:rotate-0">
            <div class="absolute inset-0 flex flex-col items-center justify-center p-6 text-center">
              <span class="font-mono text-[9px] tracking-widest uppercase text-[var(--color-accent)]/60 mb-2">{t("leadmag.book.badge")}</span>
              <h3 class="font-display text-lg md:text-xl font-bold text-[var(--color-text-primary)] leading-tight mb-3">{t("leadmag.book.title")}</h3>
              <div class="w-8 h-px bg-gradient-to-r from-[var(--color-accent)] to-[var(--color-cta)] mb-3"></div>
              <span class="font-mono text-[9px] tracking-widest uppercase text-[var(--color-text-secondary)]/50">Flintlock Studio</span>
            </div>
          </div>
          <!-- Glow behind -->
          <div class="absolute -inset-8 rounded-full bg-[var(--color-accent)]/5 blur-3xl pointer-events-none"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function() {
    var btn = document.getElementById("leadmag-submit");
    var emailInput = document.getElementById("leadmag-email") as HTMLInputElement;
    var status = document.getElementById("leadmag-status");
    var form = document.getElementById("leadmag-form");
    if (!btn || !emailInput || !status || !form) return;

    btn.addEventListener("click", function() {
      var email = emailInput.value.trim();
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        status.textContent = status.getAttribute("data-i18n-invalid");
        status.className = "font-mono text-xs mt-3 text-red-400";
        status.classList.remove("hidden");
        return;
      }

      btn.setAttribute("disabled", "true");
      btn.textContent = "...";

      var WORKER_URL = "https://flintlock-forms.abdellah-erraoui.workers.dev";

      fetch(WORKER_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          type: "lead magnet",
          email: email,
          lang: location.pathname.startsWith("/fr") ? "fr" : "en",
        }),
      }).then(function(r) {
        if (!r.ok) throw new Error("HTTP " + r.status);
        return r.json();
      }).then(function(data) {
        if (!data.ok) throw new Error(data.error || "Server error");
        /* Trigger PDF download */
        var a = document.createElement("a");
        a.href = "/ebook.pdf";
        a.download = "Flintlock-25-Processus-Automatiser.pdf";
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);

        form.classList.add("hidden");
        status.textContent = status.getAttribute("data-i18n-success");
        status.className = "font-mono text-xs mt-3 text-[var(--color-accent)]";
        status.classList.remove("hidden");
      }).catch(function() {
        btn.removeAttribute("disabled");
        btn.textContent = btn.getAttribute("data-cta-label");
        status.textContent = status.getAttribute("data-i18n-server-error");
        status.className = "font-mono text-xs mt-3 text-red-400";
        status.classList.remove("hidden");
      });
    });
  })();
</script>
