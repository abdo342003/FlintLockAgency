---
import { useTranslations, type Lang } from "../i18n/util";
import { Icon } from "astro-icon/components";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const otherLang: Lang = lang === "en" ? "fr" : "en";
const otherHref = otherLang === "fr" ? "/fr/" : "/";

const blogHref = lang === "fr" ? "/fr/blog" : "/blog";

const navItems = [
  { index: "01", key: "services", href: "#services" },
  { index: "02", key: "work", href: "#proof" },
  { index: "03", key: "team", href: "#team" },
  { index: "04", key: "faq", href: "#faq" },
  { index: "05", key: "blog", href: blogHref },
  { index: "06", key: "contact", href: "#contact" },
] as const;
---

<header
  id="navbar"
  class="fixed top-0 z-50 w-full transition-all duration-400 ease-[cubic-bezier(0.22,1,0.36,1)]"
  style="background: color-mix(in srgb, var(--onyx) 82%, transparent); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);"
>
  <!-- Scroll progress bar -->
  <div id="scroll-progress" class="absolute bottom-0 left-0 h-[1px] z-10" style="width: 0%; background: linear-gradient(90deg, var(--color-accent), var(--color-ember));"></div>

  <!-- Bottom edge glow (appears on scroll) -->
  <div id="nav-bottom-glow" class="absolute bottom-0 left-0 right-0 h-[1px] opacity-0 transition-opacity duration-400" style="background: linear-gradient(90deg, transparent, rgba(25,227,240,0.1), rgba(255,122,26,0.08), transparent);"></div>

  <!-- Inner container -->
  <div class="flex items-center justify-between px-[var(--margin-mobile)] md:px-[var(--margin-desktop)] py-[var(--unit)]" style="max-width: var(--container-max); margin: 0 auto;">
    <!-- Left: Logo emblem + tag -->
    <a href="/" class="flex items-center gap-2 sm:gap-3 no-underline group min-w-0">
      <img src="/logo-96.png" alt="Flintlock" class="h-10 sm:h-12 w-auto object-contain flex-shrink-0" width="96" height="96" fetchpriority="high" />
      <div class="flex flex-col leading-tight min-w-0">
        <span class="font-display text-sm sm:text-base md:text-lg font-extrabold tracking-[0.15em] text-[var(--color-off-white)] truncate">FLINTLOCK</span>
        <span class="font-mono text-[9px] sm:text-[10px] md:text-[11px] tracking-[0.12em] uppercase opacity-40 text-[var(--color-off-white)] hidden sm:block">Studio &middot; Est. 2026</span>
      </div>
    </a>

    <!-- Center: Desktop nav -->
    <nav class="hidden md:flex items-center gap-5 lg:gap-7" aria-label="Main navigation">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="nav-link relative font-mono text-[11px] tracking-[0.15em] uppercase no-underline text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors duration-300 py-2"
        >
          <span class="font-medium">{t(`nav.${item.key}`)}</span>
          <span class="nav-underline" aria-hidden="true"></span>
        </a>
      ))}
    </nav>

    <!-- Right: Status + Lang switch + CTA -->
    <div class="flex items-center gap-2 sm:gap-3 lg:gap-4 flex-shrink-0">
      <!-- Status pill (desktop) -->
      <div class="status-pill hidden lg:flex items-center gap-2 px-3 py-1.5 rounded-full border border-[var(--color-accent)]/10 bg-[var(--color-accent)]/3">
        <span class="status-dot relative w-1.5 h-1.5 rounded-full" style="background: var(--color-accent);"></span>
        <span class="font-mono text-[10px] tracking-wide text-[var(--color-text-secondary)] whitespace-nowrap">{t("nav.status")}</span>
      </div>

      <!-- EN/FR physical toggle switch -->
      <button
        id="lang-switch"
        role="switch"
        aria-checked={lang === "fr" ? "true" : "false"}
        aria-label={lang === "en" ? "Switch to French" : "Passer en anglais"}
        data-other-href={otherHref}
        data-persist="true"
        class="lang-toggle relative flex items-center gap-1 px-2.5 sm:px-3 py-1.5 sm:py-2 rounded-full border border-[var(--color-border)] bg-[var(--color-onyx)]/60 cursor-pointer transition-colors duration-300 hover:border-[var(--color-accent)]/30 focus-visible:outline-2 focus-visible:outline-[var(--color-accent)]"
        style="min-width: 56px;"
      >
        <span class={`font-mono text-[10px] font-bold tracking-wider transition-colors duration-300 ${lang === "en" ? "text-[var(--color-accent)]" : "text-[var(--color-text-secondary)]/40"}`}>EN</span>
        <span class="lang-knob relative w-4 h-4 rounded-full transition-transform duration-300" style="background: var(--color-accent); transform: translateX(0);"></span>
        <span class={`font-mono text-[10px] font-bold tracking-wider transition-colors duration-300 ${lang === "fr" ? "text-[var(--color-accent)]" : "text-[var(--color-text-secondary)]/40"}`}>FR</span>
      </button>

      <!-- Ignition CTA (desktop) -->
      <a
        href="#contact"
        class="ignition-cta hidden md:inline-flex items-center gap-2 px-5 py-2.5 no-underline font-bold text-[11px] uppercase tracking-[0.15em] rounded-[var(--radius-md)] relative overflow-hidden group"
        style="background: var(--color-cta); color: #000;"
      >
        <span class="relative z-10 flex items-center gap-2">
          <Icon name="lucide:zap" class="w-3.5 h-3.5" />
          <span>{t("nav.book")}</span>
        </span>
        <span class="cta-glow absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500" aria-hidden="true"></span>
        <span class="cta-spark absolute pointer-events-none opacity-0 group-hover:opacity-100" aria-hidden="true"></span>
      </a>

      <!-- Hamburger (mobile) -->
      <button
        id="mobile-menu-btn"
        class="md:hidden text-[var(--color-off-white)] bg-transparent border-none cursor-pointer p-2 sm:p-2.5 transition-transform duration-200 active:scale-90"
        style="touch-action: manipulation; min-width: 44px; min-height: 44px; display: flex; align-items: center; justify-content: center;"
        aria-label={lang === "en" ? "Open menu" : "Ouvrir le menu"}
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <Icon name="lucide:menu" class="w-5 h-5 sm:w-6 sm:h-6" />
      </button>
    </div>
  </div>

</header>

<!-- Mobile full-screen overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] flex flex-col items-center justify-center md:hidden transition-all duration-400 ease-[cubic-bezier(0.22,1,0.36,1)]"
  style="background: color-mix(in srgb, var(--onyx) 97%, transparent); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); clip-path: circle(0% at calc(100% - 40px) 32px);"
  aria-label={lang === "en" ? "Mobile navigation" : "Navigation mobile"}
  role="dialog"
  aria-modal="true"
  hidden
>
  <!-- Blueprint grid background -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background-image: linear-gradient(rgba(25,227,240,0.035) 1px, transparent 1px), linear-gradient(90deg, rgba(25,227,240,0.035) 1px, transparent 1px); background-size: 40px 40px;"></div>

  <!-- Close button -->
  <button
    id="mobile-menu-close"
    class="absolute top-5 right-5 text-[var(--color-off-white)] bg-[var(--color-surface-2)]/50 border border-[var(--color-border)] rounded-full cursor-pointer p-3 z-10"
    style="touch-action: manipulation; min-width: 44px; min-height: 44px;"
    aria-label={lang === "en" ? "Close menu" : "Fermer le menu"}
  >
    <Icon name="lucide:x" class="w-6 h-6" />
  </button>

  <!-- Mobile content -->
  <div class="flex flex-col items-center gap-8 relative z-[1] w-full max-w-sm px-6">
    <!-- Logo area -->
    <div class="flex flex-col items-center gap-2 mb-4 mobile-stagger">
      <div class="w-12 h-12">
        <svg viewBox="0 0 44 44" class="w-full h-full" aria-hidden="true" style="color: var(--color-accent);">
          <path d="M22 3 L38 10 L38 32 L22 41 L6 32 L6 10 Z" stroke="currentColor" stroke-width="1.1" fill="none" opacity="0.55" />
          <circle cx="22" cy="21" r="11" stroke="currentColor" stroke-width="0.5" fill="none" opacity="0.2" />
          <rect x="15" y="18" width="14" height="11" rx="1.5" stroke="currentColor" stroke-width="1" fill="none" />
          <path d="M17 18 L17 14 Q17 10 22 10 Q27 10 27 14 L27 18" stroke="currentColor" stroke-width="1" fill="none" />
          <circle cx="22" cy="23" r="2.5" stroke="currentColor" stroke-width="0.7" fill="none" />
          <path d="M22 20.5 L22 18" stroke="currentColor" stroke-width="0.9" stroke-linecap="round" />
          <path d="M10 9 L20 9 L16 15 L34 15" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" fill="none" opacity="0.7" />
        </svg>
      </div>
      <span class="font-display text-lg font-extrabold tracking-[0.15em] text-[var(--color-off-white)]">FLINTLOCK</span>
      <span class="font-mono text-[10px] tracking-[0.12em] uppercase opacity-30 text-[var(--color-off-white)]">Studio &middot; Est. 2026</span>
    </div>

    <!-- Mobile nav links -->
    <nav class="flex flex-col items-center gap-5" aria-label={lang === "en" ? "Mobile navigation" : "Navigation mobile"}>
      {navItems.map((item, i) => (
        <a
          href={item.href}
          class="mobile-nav-link flex items-center gap-3 no-underline font-mono text-lg tracking-[0.15em] uppercase py-3 mobile-stagger"
          style={`transition-delay: ${0.08 * i}s`}
        >
          <span class="font-medium text-[var(--color-off-white)] hover:text-[var(--color-accent)] transition-colors duration-300">{t(`nav.${item.key}`)}</span>
        </a>
      ))}
    </nav>

    <!-- Status pill (mobile) -->
    <div class="flex items-center gap-2 px-5 py-3 rounded-full border border-[var(--color-accent)]/10 mobile-stagger" style="transition-delay: 0.4s;">
      <span class="w-2 h-2 rounded-full status-dot" style="background: var(--color-accent);"></span>
      <span class="font-mono text-xs tracking-wide text-[var(--color-text-secondary)]">{t("nav.status")}</span>
    </div>

    <!-- Lang toggle (mobile) -->
    <button
      role="switch"
      aria-checked={lang === "fr" ? "true" : "false"}
      aria-label={lang === "en" ? "Switch to French" : "Passer en anglais"}
      data-other-href={otherHref}
      data-persist="true"
      class="lang-toggle flex items-center gap-2 px-4 py-3 rounded-full border border-[var(--color-border)] bg-[var(--color-onyx)]/60 cursor-pointer mobile-stagger"
      style="transition-delay: 0.48s;"
    >
      <span class={`font-mono text-xs font-bold tracking-wider transition-colors duration-300 ${lang === "en" ? "text-[var(--color-accent)]" : "text-[var(--color-text-secondary)]/40"}`}>EN</span>
      <span class="w-5 h-5 rounded-full transition-transform duration-300" style="background: var(--color-accent);"></span>
      <span class={`font-mono text-xs font-bold tracking-wider transition-colors duration-300 ${lang === "fr" ? "text-[var(--color-accent)]" : "text-[var(--color-text-secondary)]/40"}`}>FR</span>
    </button>

    <!-- Ignition CTA (mobile) -->
    <a
      href="#contact"
      class="mobile-nav-link inline-flex items-center gap-2.5 px-8 py-4 no-underline font-bold text-sm uppercase tracking-[0.15em] rounded-[var(--radius-md)] mobile-stagger relative overflow-hidden group"
      style="background: var(--color-cta); color: #000; transition-delay: 0.56s;"
    >
      <Icon name="lucide:zap" class="w-4 h-4" />
      <span>{t("nav.book")}</span>
      <span class="cta-glow absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500"></span>
    </a>
  </div>
</div>

<style is:global>
  .nav-link .nav-underline {
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--color-accent);
    transition: width 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .nav-link:hover .nav-underline,
  .nav-link.active .nav-underline {
    width: 100%;
  }
  .nav-link.active {
    color: var(--color-accent);
  }

  /* ─── Status dot pulse ─── */
  .status-dot::after {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    background: var(--color-accent);
    opacity: 0.3;
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { transform: scale(1); opacity: 0.3; }
    50% { transform: scale(1.8); opacity: 0.05; }
  }

  /* ─── EN/FR lang toggle ─── */
  .lang-toggle[aria-checked="true"] .lang-knob {
    transform: translateX(10px);
  }
  .lang-toggle[aria-checked="false"] .lang-knob {
    transform: translateX(0px);
  }

  /* ─── Ignition CTA heat glow ─── */
  .cta-glow {
    background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(255, 122, 26, 0.5), transparent 70%);
  }
  .ignition-cta:hover {
    box-shadow: 0 0 20px rgba(255, 122, 26, 0.5), 0 0 40px rgba(255, 122, 26, 0.2);
  }

  /* ─── Spark animation on CTA hover ─── */
  .cta-spark {
    top: -20%;
    left: -20%;
    width: 140%;
    height: 140%;
    background: radial-gradient(circle at 30% 40%, rgba(255,255,255,0.15), transparent 60%);
    animation: spark-fly 0.8s ease-out infinite;
  }
  @keyframes spark-fly {
    0% { transform: translate(0, 0) scale(0.8); opacity: 1; }
    100% { transform: translate(15%, -15%) scale(1.4); opacity: 0; }
  }

  /* ─── Mobile overlay open/close ─── */
  #mobile-menu[hidden] {
    display: none !important;
  }
  #mobile-menu.open {
    clip-path: circle(150% at 50% 50%);
  }

  /* ─── Mobile stagger animation ─── */
  #mobile-menu.open .mobile-stagger {
    opacity: 0;
    transform: translateY(16px);
    animation: stagger-in 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes stagger-in {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ─── Scrolled capsule state (desktop only) ─── */
  @media (min-width: 768px) {
    #navbar.scrolled {
      width: 90%;
      max-width: 1000px;
      left: 50%;
      transform: translateX(-50%);
      border-radius: 0;
      clip-path: polygon(16px 0%, calc(100% - 16px) 0%, 100% 16px, 100% calc(100% - 16px), calc(100% - 16px) 100%, 16px 100%, 0% calc(100% - 16px), 0% 16px);
    }
    #navbar.scrolled.hidden-nav {
      transform: translateX(-50%) translateY(-120%) !important;
    }
  }

  /* ─── Hide on scroll down / show on scroll up ─── */
  #navbar.hidden-nav {
    transform: translateY(-120%) !important;
  }
  #navbar.scrolled.hidden-nav {
    transform: translateX(-50%) translateY(-120%) !important;
  }

  /* ─── Reduced motion ─── */
  @media (prefers-reduced-motion: reduce) {
    .status-dot::after { animation: none; }
    .cta-spark { display: none; }
    .ignition-cta:hover { box-shadow: none; }
    .nav-link .nav-underline { transition: none; }
    .nav-link:hover .nav-underline { width: 0; }
    #navbar { transition: none; }
    #navbar.scrolled { transition: none; }
    #mobile-menu { transition: none; }
    #mobile-menu.open .mobile-stagger {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .lang-toggle .lang-knob { transition: none; }
    #scroll-progress { display: none; }
    #nav-bottom-glow { opacity: 0 !important; }
  }
</style>

<script>
  (function () {
    function initHeader() {
      var navbar = document.getElementById("navbar");
      var menuBtn = document.getElementById("mobile-menu-btn");
      var menuClose = document.getElementById("mobile-menu-close");
      var menu = document.getElementById("mobile-menu");
      var langToggles = document.querySelectorAll(".lang-toggle");
      var mobileNavLinks = document.querySelectorAll(".mobile-nav-link");

      if (!navbar) return;

      var scrollProgress = document.getElementById("scroll-progress");
      var ticking = false;
      var lastScroll = 0;
      var scrollThreshold = 50;
      var hideThreshold = 100;
      var isScrolled = false;

      /* ─── Scroll handler ─── */
      function onScroll() {
        var scrollY = window.scrollY;

        /* Morph to capsule at threshold */
        if (scrollY > scrollThreshold && !isScrolled) {
          navbar.classList.add("scrolled");
          isScrolled = true;
        } else if (scrollY <= scrollThreshold && isScrolled) {
          navbar.classList.remove("scrolled");
          navbar.classList.remove("hidden-nav");
          isScrolled = false;
        }

        /* Hide on scroll down / show on scroll up */
        if (scrollY > hideThreshold) {
          if (scrollY > lastScroll) {
            navbar.classList.add("hidden-nav");
          } else {
            navbar.classList.remove("hidden-nav");
          }
        } else {
          navbar.classList.remove("hidden-nav");
        }

        /* Update scroll progress bar */
        if (scrollProgress) {
          var docHeight = document.documentElement.scrollHeight - window.innerHeight;
          var pct = docHeight > 0 ? (scrollY / docHeight) * 100 : 0;
          scrollProgress.style.width = pct + "%";
        }

        lastScroll = scrollY;
        ticking = false;
      }

      /* ─── Active nav section on scroll ─── */
      var sections = document.querySelectorAll("section[id]");
      var navLinks = document.querySelectorAll(".nav-link");
      if (sections.length && navLinks.length) {
        var sectionObs = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              var id = entry.target.id;
              navLinks.forEach(function (link) {
                link.classList.toggle("active", link.getAttribute("href") === "#" + id);
              });
            }
          });
        }, { rootMargin: "-40% 0px -55% 0px" });
        sections.forEach(function (s) { sectionObs.observe(s); });
      }

      window.addEventListener("scroll", function () {
        if (!ticking) {
          requestAnimationFrame(onScroll);
          ticking = true;
        }
      });

      /* ─── Lang toggle — physical switch ─── */
      langToggles.forEach(function (toggle) {
        toggle.addEventListener("click", function () {
          var href = this.getAttribute("data-other-href");
          if (href) {
            localStorage.setItem("flintlock-lang", href === "/fr/" ? "fr" : "en");
            window.location.href = href;
          }
        });

        /* Keyboard: Enter/Space toggles */
        toggle.addEventListener("keydown", function (e) {
          if (e.key === "Enter" || e.key === " ") {
            e.preventDefault();
            this.click();
          }
        });
      });

      /* ─── Mobile menu ─── */
      var lastFocused = null;

      function openMenu() {
        if (!menu || !menuBtn) return;
        lastFocused = document.activeElement;
        menu.removeAttribute("hidden");
        /* Force reflow then add open class for clip-path animation */
        void menu.offsetHeight;
        menu.classList.add("open");
        menuBtn.setAttribute("aria-expanded", "true");
        document.body.style.overflow = "hidden";
        if (menuClose) menuClose.focus();
      }

      function closeMenu() {
        if (!menu || !menuBtn) return;
        menu.classList.remove("open");
        menuBtn.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
        setTimeout(function () {
          menu.setAttribute("hidden", "");
          if (lastFocused) lastFocused.focus();
        }, 450);
      }

      if (menuBtn && menu) {
        menuBtn.addEventListener("click", openMenu);

        if (menuClose) {
          menuClose.addEventListener("click", closeMenu);
        }

        mobileNavLinks.forEach(function (link) {
          link.addEventListener("click", closeMenu);
        });

        /* Escape to close */
        document.addEventListener("keydown", function (e) {
          if (e.key === "Escape" && menu.classList.contains("open")) {
            closeMenu();
          }
        });

        /* Focus trap */
        menu.addEventListener("keydown", function (e) {
          if (e.key !== "Tab") return;
          var focusable = menu.querySelectorAll('button, a, [tabindex]:not([tabindex="-1"])');
          if (focusable.length === 0) return;
          var first = focusable[0];
          var last = focusable[focusable.length - 1];
          if (e.shiftKey && document.activeElement === first) {
            e.preventDefault();
            last.focus();
          } else if (!e.shiftKey && document.activeElement === last) {
            e.preventDefault();
            first.focus();
          }
        });
      }

      /* ─── Reduced motion: disable magnetic ─── */
      var prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (!prefersReduced) {
        /* Magnetic pull on nav links */
        var navLinksMagnetic = document.querySelectorAll(".nav-link");
        navLinksMagnetic.forEach(function (link) {
          link.addEventListener("mousemove", function (e) {
            var rect = link.getBoundingClientRect();
            var x = e.clientX - rect.left - rect.width / 2;
            var y = e.clientY - rect.top - rect.height / 2;
            link.style.transform = "translate(" + (x * 0.12) + "px, " + (y * 0.12) + "px)";
          });
          link.addEventListener("mouseleave", function () {
            link.style.transform = "translate(0px, 0px)";
          });
        });
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initHeader);
    } else {
      initHeader();
    }
  })();
</script>
