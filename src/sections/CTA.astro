---
import { useTranslations, type Lang } from "../i18n/util";
import { Icon } from "astro-icon/components";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="contact" class="py-[var(--stack-lg)] px-[var(--margin-mobile)] md:px-[var(--margin-desktop)] relative section-glow-ember overflow-hidden">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background: radial-gradient(ellipse 50% 40% at 50% 100%, rgba(255,122,26,0.06) 0%, transparent 70%);"></div>
  <div class="mx-auto text-center relative" style="max-width: 640px;">
    <div class="reveal">
      <p class="section-kicker text-[var(--color-accent)]">{t("cta.kicker")}</p>
      <h2 class="section-title mb-4">{t("cta.title")}</h2>
      <p class="text-base md:text-lg text-[var(--color-text-secondary)] mb-10">{t("cta.desc")}</p>
    </div>

    <div class="cta-card rounded-[var(--radius-lg)] border border-[var(--color-border)]/50 bg-[var(--color-surface-2)] p-6 md:p-8 mb-6 shadow-[inset_1px_1px_0px_0px_rgba(255,122,26,0.08)] reveal">
      <a href="https://wa.me/212706570686" target="_blank" rel="noopener" class="cta-forge w-full inline-flex items-center justify-center gap-2 px-8 py-4 rounded-[var(--radius-md)] text-black font-bold text-sm uppercase tracking-widest transition-all duration-300 cursor-pointer no-underline">
        <Icon name="lucide:message-circle" class="w-4 h-4" />
        <span>{t("cta.button")}</span>
        <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
    </div>

    <p class="font-mono text-[10px] tracking-widest uppercase text-[var(--color-off-white)]/30 mb-4 reveal">— {t("cta.or")} —</p>

    <div class="cta-card rounded-[var(--radius-lg)] border border-[var(--color-border)]/50 bg-[var(--color-surface-2)] p-6 md:p-8 mb-8 shadow-[inset_1px_1px_0px_0px_rgba(255,122,26,0.08)] reveal">
      <form id="contact-form" class="space-y-5" data-lang={lang}>
        <div>
          <label for="contact-name" class="sr-only">{t("cta.name.placeholder")}</label>
          <input type="text" id="contact-name" name="name" placeholder={t("cta.name.placeholder")} class="w-full bg-[var(--color-onyx)]/60 border border-[var(--color-border)] border-l-2 border-l-[var(--color-accent)]/50 px-4 py-4 text-sm text-[var(--color-off-white)] placeholder-[var(--color-off-white)]/50 input-forge rounded-[var(--radius-md)]" required />
        </div>
        <div>
          <label for="contact-email" class="sr-only">{t("cta.email.placeholder")}</label>
          <input type="email" id="contact-email" name="email" placeholder={t("cta.email.placeholder")} class="w-full bg-[var(--color-onyx)]/60 border border-[var(--color-border)] border-l-2 border-l-[var(--color-accent)]/50 px-4 py-4 text-sm text-[var(--color-off-white)] placeholder-[var(--color-off-white)]/50 input-forge rounded-[var(--radius-md)]" required />
        </div>
        <div>
          <label for="contact-message" class="sr-only">{t("cta.message.placeholder")}</label>
          <textarea id="contact-message" name="message" placeholder={t("cta.message.placeholder")} rows={4} class="w-full bg-[var(--color-onyx)]/60 border border-[var(--color-border)] border-l-2 border-l-[var(--color-accent)]/50 px-4 py-4 text-sm text-[var(--color-off-white)] placeholder-[var(--color-off-white)]/50 input-forge rounded-[var(--radius-md)] resize-none" required></textarea>
        </div>
        <div id="form-status" class="hidden font-mono text-xs tracking-wide text-center py-2 rounded-[var(--radius-md)]" role="status" aria-live="polite"></div>
        <button type="submit" class="w-full inline-flex items-center justify-center gap-2 px-8 py-4 rounded-[var(--radius-md)] border border-[var(--color-accent)]/30 bg-transparent text-[var(--color-accent)] font-bold text-sm uppercase tracking-widest transition-all duration-300 cursor-pointer hover:bg-[var(--color-accent)]/10">
          <Icon name="lucide:send" class="w-4 h-4" />
          <span>{t("cta.send")}</span>
        </button>
        <p class="flex items-center justify-center gap-1.5 font-mono text-[10px] text-[var(--color-text-secondary)]/40 pt-1">
          <Icon name="lucide:clock" class="w-3 h-3" />
          {t("cta.response.guarantee")}
        </p>
      </form>
    </div>

    <div id="form-result" class="hidden" data-i18n-success-title={t("cta.success.title")} data-i18n-success-desc={t("cta.success.desc")} data-i18n-error={t("cta.error")} data-lang={lang}></div>

    <div class="flex flex-col items-center gap-4 reveal">
      <span class="font-mono text-[10px] tracking-widest uppercase text-[var(--color-off-white)]/40">{t("cta.alt")}</span>
      <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1">
        <a href="mailto:contact@flintlockagency.com" class="flex items-center gap-2 text-[var(--color-accent)] no-underline hover:underline text-xs sm:text-sm py-2">
          <Icon name="lucide:mail" class="w-4 h-4 flex-shrink-0" />
          contact@flintlockagency.com
        </a>
        <span class="text-[var(--color-off-white)]/15 hidden sm:inline">|</span>
        <a href="tel:+212706570686" class="flex items-center gap-2 text-[var(--color-off-white)]/60 no-underline hover:text-[var(--color-accent)] transition-colors text-xs sm:text-sm py-2">
          <Icon name="lucide:phone" class="w-4 h-4 flex-shrink-0" />
          +212 706-570686
        </a>
        <span class="text-[var(--color-off-white)]/15 hidden sm:inline">|</span>
        <a href="https://wa.me/212706570686" class="flex items-center gap-2 text-[var(--color-off-white)]/60 no-underline hover:text-[var(--color-accent)] transition-colors text-xs sm:text-sm py-2" target="_blank" rel="noopener">
          <Icon name="lucide:message-circle" class="w-4 h-4 flex-shrink-0" />
          {t("cta.whatsapp")}
        </a>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .cta-card {
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .cta-card:focus-within {
    border-color: rgba(25, 227, 240, 0.2);
    box-shadow: 0 0 24px rgba(25, 227, 240, 0.06), inset 1px 1px 0 0 rgba(25, 227, 240, 0.08);
  }
  .input-forge {
    transition: border-color 0.2s ease, box-shadow 0.2s ease, border-left-color 0.2s ease;
  }
  .input-forge:focus {
    border-color: rgba(25, 227, 240, 0.25);
    border-left-color: var(--color-accent);
    box-shadow: 0 0 0 1px rgba(25, 227, 240, 0.2);
    outline: 2px solid rgba(25, 227, 240, 0.3);
    outline-offset: 1px;
  }
</style>

<script>
  (function () {
    var form = document.getElementById("contact-form");
    var result = document.getElementById("form-result");
    if (!form) return;

    form.addEventListener("submit", function (e) {
      e.preventDefault();
      var submitBtn = form.querySelector('[type="submit"]');
      var fd = new FormData(form);

      submitBtn.disabled = true;

      var WORKER_URL = "https://flintlock-forms.abdellah-erraoui.workers.dev";

      fetch(WORKER_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          type: "contact",
          name: fd.get("name"),
          email: fd.get("email"),
          message: fd.get("message"),
          lang: form.getAttribute("data-lang"),
        }),
      })
        .then(function (r) { if (!r.ok) throw new Error("HTTP " + r.status); return r.json(); })
        .then(function (data) {
          if (data.ok) {
            form.classList.add("hidden");
            result.classList.remove("hidden");
            var resultI18n = result;
            result.innerHTML =
              '<div class="cta-card rounded-[var(--radius-lg)] border border-[var(--color-accent)]/20 bg-[var(--color-surface-2)] p-8 mb-8 text-center">' +
              '<div class="w-12 h-12 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center mx-auto mb-4">' +
              '<svg class="w-6 h-6 text-[var(--color-accent)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>' +
              "</div>" +
              '<p class="font-bold text-lg text-[var(--color-off-white)] mb-1">' +
              resultI18n.getAttribute("data-i18n-success-title") +
              "</p>" +
              '<p class="text-sm text-[var(--color-text-secondary)]">' +
              resultI18n.getAttribute("data-i18n-success-desc") +
              "</p></div>";
          } else {
            throw new Error(data.error);
          }
        })
        .catch(function () {
          submitBtn.disabled = false;
          result.classList.remove("hidden");
          result.innerHTML =
            '<p class="font-mono text-xs text-red-400 text-center">' +
            result.getAttribute("data-i18n-error") +
            "</p>";
        });
    });
  })();
</script>
