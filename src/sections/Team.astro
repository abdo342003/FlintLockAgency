---
import { useTranslations, type Lang } from "../i18n/util";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const founders = [
  { id: "abdo", image: "/Abdellah.jpeg", alt: "Abdellah ERRAOUI" },
  { id: "faris", image: "/Faris.jpeg", alt: "Faris BAHBAH" },
];
---

<section id="team" class="py-[var(--stack-lg)] px-[var(--margin-mobile)] md:px-[var(--margin-desktop)] relative">
  <div class="mx-auto" style="max-width: var(--container-max);">
    <div class="reveal">
      <p class="section-kicker">{t("team.kicker")}</p>
      <h2 class="section-title mb-4">{t("team.title")}</h2>
      <p class="text-sm md:text-base text-[var(--color-text-secondary)] max-w-lg mb-12 leading-relaxed border-l-2 border-[var(--color-accent)]/30 pl-4">
        {t("team.tagline")}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-3xl">
      {founders.map((f, i) => (
        <div class="team-card relative overflow-hidden rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-2)] p-6 md:p-8 text-center shadow-[inset_1px_1px_0px_0px_rgba(25,227,240,0.08)] hover:-translate-y-1 hover:shadow-[0_0_16px_rgba(25,227,240,0.12)] transition-all duration-300 group reveal" style={`transition-delay: ${0.15 * i}s`}>
          <div class="w-20 h-20 mx-auto mb-4 rounded-full overflow-hidden ring-2 ring-[var(--color-bg)] shadow-[0_0_20px_rgba(25,227,240,0.1)]">
            <img src={f.image} alt={f.alt} class="w-full h-full object-cover" width="80" height="80" loading="lazy" decoding="async" />
          </div>
          <h3 class="font-bold text-lg md:text-xl text-[var(--color-text-primary)]">{t(`team.${f.id}.name`)}</h3>
          <p class="font-mono text-xs tracking-widest uppercase text-[var(--color-accent)] mb-4">{t(`team.${f.id}.role`)}</p>
          <p class="text-sm md:text-base text-[var(--color-text-secondary)] leading-relaxed">{t(`team.${f.id}.desc`)}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .team-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    translate: -50% 0;
    width: 40%;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-accent), transparent);
    opacity: 0;
    border-radius: 0 0 2px 2px;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }
  .team-card.revealed::before {
    opacity: 0.4;
  }
</style>
