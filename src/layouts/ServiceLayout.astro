---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../sections/Header.astro";
import Footer from "../sections/Footer.astro";
import ForgeBackground from "../components/ForgeBackground.astro";
import { useTranslations, type Lang } from "../i18n/util";

interface Props {
  lang: Lang;
  title: string;
  description: string;
  serviceSlug: string;
}

const { lang, title, description, serviceSlug } = Astro.props;
const t = useTranslations(lang);
const siteUrl = "https://flintlockagency.com";
const canonicalURL = new URL(Astro.url.pathname, siteUrl).href;

const otherLang: Lang = lang === "en" ? "fr" : "en";
const translationSlug = `/services/${serviceSlug}/`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: lang === "fr" ? "Accueil" : "Home", item: lang === "fr" ? `${siteUrl}/fr/` : siteUrl },
    { "@type": "ListItem", position: 2, name: t("nav.services"), item: lang === "fr" ? `${siteUrl}/fr/services` : `${siteUrl}/services` },
    { "@type": "ListItem", position: 3, name: t(`service.${serviceSlug}.title`), item: canonicalURL },
  ],
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: t(`service.${serviceSlug}.title`),
  description: t(`service.${serviceSlug}.desc`),
  provider: {
    "@type": "Organization",
    name: "Flintlock",
    url: siteUrl,
  },
  areaServed: { "@type": "Place", name: "Worldwide" },
};

const hreflangLinks = [
  { lang: otherLang, href: `${otherLang === "fr" ? "/fr" : ""}${translationSlug}` },
];
---

<BaseLayout lang={lang} title={`${t(`service.${serviceSlug}.title`)} — Flintlock`} description={description} hreflangAlternates={hreflangLinks}>
  <ForgeBackground slot="background" />
  <Header slot="header" lang={lang} />

  <section class="pt-32 pb-20 px-[var(--margin-mobile)] md:px-[var(--margin-desktop)] relative" style="background: radial-gradient(ellipse 60% 40% at 50% 0%, rgba(25,227,240,0.04) 0%, transparent 60%);">
    <div class="mx-auto" style="max-width: var(--container-max);">
      <a href={lang === "fr" ? "/fr/services" : "/services"} class="inline-flex items-center gap-1 text-sm text-[var(--color-accent)] no-underline hover:underline mb-8">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        {t("nav.services")}
      </a>

      <div class="reveal max-w-3xl">
        <p class="section-kicker">{t(`service.${serviceSlug}.title`)}</p>
        <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-[var(--color-text-primary)] leading-tight mb-6">{t(`service.${serviceSlug}.page.hero.title`)}</h1>
        <p class="text-lg md:text-xl text-[var(--color-text-secondary)] leading-relaxed mb-8">{t(`service.${serviceSlug}.page.hero.desc`)}</p>
        <a href="https://wa.me/212706570686" target="_blank" rel="noopener" class="ignition-cta inline-flex items-center gap-2 px-6 py-3 no-underline font-bold text-sm uppercase tracking-[0.12em] rounded-[var(--radius-md)]" style="background: var(--color-cta); color: #000;">
          {t("servicehub.cta")}
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <section class="py-[var(--stack-lg)] px-[var(--margin-mobile)] md:px-[var(--margin-desktop)] relative bg-surface section-glow-cyan">
    <div class="mx-auto" style="max-width: var(--container-max);">
      <div class="reveal mb-12">
        <p class="section-kicker">{t("services.title")}</p>
        <h2 class="section-title">{t(`service.${serviceSlug}.page.process.title`)}</h2>
        <p class="text-base md:text-lg text-[var(--color-text-secondary)] max-w-2xl mt-4">{t(`service.${serviceSlug}.page.process.desc`)}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-[var(--gutter)]">
        {[1,2,3,4,5,6].map((i) => (
          <div class="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-2)] p-6 md:p-7 shadow-[inset_1px_1px_0px_0px_rgba(25,227,240,0.08)] hover:-translate-y-1 hover:shadow-[0_0_16px_rgba(25,227,240,0.12)] transition-all duration-300 reveal" style={`transition-delay: ${0.08 * i}s`}>
            <div class="w-10 h-10 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center mb-4">
              <span class="font-mono text-sm font-bold text-[var(--color-accent)]">{i}</span>
            </div>
            <p class="font-bold text-[var(--color-text-primary)] leading-snug">{t(`service.${serviceSlug}.page.feature${i}`)}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <slot />

  <section class="py-[var(--stack-lg)] px-[var(--margin-mobile)] md:px-[var(--margin-desktop)] relative">
    <div class="mx-auto" style="max-width: var(--container-max);">
      <div class="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-2)] p-8 md:p-12 text-center reveal" style="background: radial-gradient(ellipse 50% 50% at 50% 50%, rgba(255,122,26,0.06) 0%, transparent 60%);">
        <h2 class="font-display text-2xl md:text-3xl font-bold text-[var(--color-text-primary)] mb-4">{t(`service.${serviceSlug}.page.cta.title`)}</h2>
        <p class="text-[var(--color-text-secondary)] max-w-lg mx-auto mb-8">{t(`service.${serviceSlug}.page.cta.desc`)}</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="https://wa.me/212706570686" target="_blank" rel="noopener" class="ignition-cta inline-flex items-center gap-2 px-6 py-3 no-underline font-bold text-sm uppercase tracking-[0.12em] rounded-[var(--radius-md)]" style="background: var(--color-cta); color: #000;">
            {t("servicehub.cta")}
          </a>
          <a href="mailto:contact@flintlockagency.com" class="text-sm text-[var(--color-accent)] no-underline hover:underline">
            {t("cta.alt")}
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" lang={lang} />

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
</BaseLayout>

<style is:global>
  .service-case-card {
    display: block;
    text-decoration: none;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background: var(--color-surface-2);
    padding: 1.5rem;
    box-shadow: inset 1px 1px 0px 0px rgba(25,227,240,0.08);
    transition: all 0.3s ease;
  }
  .service-case-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 0 16px rgba(25,227,240,0.15);
  }
</style>
