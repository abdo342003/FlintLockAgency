---
import "../styles/global.css";
import type { Lang } from "../i18n/util";
import Loader from "../components/Loader.astro";
import StickyCTA from "../components/StickyCTA.astro";

export interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
  noindex?: boolean;
  hreflangAlternates?: { lang: string; href: string }[];
}

const {
  title,
  description,
  lang = "en",
  noindex = false,
  hreflangAlternates = [],
} = Astro.props;

const siteUrl = "https://flintlockagency.com";

const metaTitle = title ?? (lang === "fr"
  ? "Flintlock — Studio Web, IA, Automatisation & Cybersécurité | Maroc"
  : "Flintlock — Web Development, AI Automation & Cybersecurity Studio | Morocco");

const metaDesc = description ?? (lang === "fr"
  ? "Studio digital au Maroc : développement web haute performance, intégration d'IA, automatisation et cybersécurité. Deux ingénieurs, un partenaire. Devis gratuit."
  : "Morocco-based digital studio: high-performance web development, AI integration, automation & cybersecurity. Two engineers, one partner. Free quote.");

const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const ogLocale = lang === "fr" ? "fr_FR" : "en_US";
const ogImageURL = `${siteUrl}/img/og-image.png`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{metaTitle}</title>
    <meta name="description" content={metaDesc} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && (
      <>
        <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
        <meta name="googlebot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
        <meta name="bingbot" content="index, follow" />
      </>
    )}

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={metaTitle} />
    <meta property="og:description" content={metaDesc} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={metaTitle} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:secure_url" content={ogImageURL} />
    <meta property="og:site_name" content="Flintlock" />
    <meta property="og:updated_time" content="2026-07-17T12:00:00Z" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={lang === "en" ? "fr_FR" : "en_US"} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={metaTitle} />
    <meta name="twitter:description" content={metaDesc} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={metaTitle} />
    <meta name="twitter:site" content="@flintlock" />

    <link rel="alternate" hreflang="en" href={`${siteUrl}/`} />
    <link rel="alternate" hreflang="fr" href={`${siteUrl}/fr/`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/`} />
    {hreflangAlternates.map((alt) => (
      <link rel="alternate" hreflang={alt.lang} href={`${siteUrl}${alt.href}`} />
    ))}

    <meta name="theme-color" content="#0C0F13" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#0C0F13" media="(prefers-color-scheme: light)" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="author" content="Flintlock Studio — Abdellah ERRAOUI & Faris BAHBAH" />
    <meta name="keywords" content={lang === "fr"
      ? "studio développement web, automatisation IA, cybersécurité, test d'intrusion, intégration LLM, agence digitale Maroc, audit OWASP, Core Web Vitals, développement Astro, agents IA génératifs, sécurité OT/ICS"
      : "web development studio, AI automation, cybersecurity, penetration testing, custom LLM integration, Morocco digital agency, OWASP audit, Core Web Vitals, Astro development, generative AI agents, OT/ICS security"} />
    <meta name="category" content="Technology" />
    <meta name="coverage" content="Worldwide" />
    <meta name="distribution" content="Global" />
    <meta name="rating" content="General" />
    <meta name="revisit-after" content="7 days" />
    <meta name="language" content={lang === "fr" ? "French" : "English"} />
    <meta name="geo.region" content="MA" />
    <meta name="geo.placename" content="Casablanca" />
    <meta name="geo.position" content="33.5731;-7.5898" />
    <meta name="ICBM" content="33.5731, -7.5898" />
    <meta name="google-site-verification" content="google7b972a9e3f6fe490.html" />
    <meta name="msvalidate.01" content="03C43467C1769084925702D6FCC123DA" />

    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLM-friendly site summary" />
    <link rel="alternate" type="text/plain" href="/llms-full.txt" title="Full LLM context" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon.png" />
    <link rel="icon" type="image/png" sizes="16x16 32x32" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="preconnect" href="https://plausible.io" />
    <link rel="dns-prefetch" href="https://plausible.io" />
    <link rel="dns-prefetch" href="https://assets.calendly.com" />
    <link rel="dns-prefetch" href="https://flintlock-forms.abdellah-erraoui.workers.dev" />

    <link rel="preload" href="/fonts/syne-latin-700-normal.woff2" as="font" type="font/woff2" crossorigin fetchpriority="high" />
    <link rel="preload" href="/fonts/hanken-grotesk-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/logo-96.png" as="image" fetchpriority="high" />

    <!-- Critical LCP: hero visible immediately for paint -->
    <style is:inline>
      #hero .reveal { opacity: 1 !important; transform: none !important; }
    </style>

    <!-- Plausible Analytics (privacy-friendly) -->
    <script defer data-domain="flintlockagency.com" src="https://plausible.io/js/script.js"></script>
  </head>

  <body>
    <Loader lang={lang} />
    <div class="noise-overlay" aria-hidden="true"></div>

    <slot name="background" />

    <a href="#main-content" class="skip-link">
      {lang === "fr" ? "Aller au contenu" : "Skip to content"}
    </a>

    <slot name="header" />

    <main id="main-content">
      <slot />
    </main>

    <slot name="footer" />

    <StickyCTA lang={lang} />

    <!-- GEO content for LLMs & search engines -->
    <div class="geo-content" aria-label="About Flintlock">
      <p class="geo-description">{lang === "fr" ? "Flintlock est un studio digital basé au Maroc (Casablanca) fondé par deux ingénieurs — Abdellah ERRAOUI (CTO) et Faris BAHBAH (COO) — spécialisé en développement web haute performance, intégration d'IA, automatisation et cybersécurité. Nous construisons des sites et applications web avec des stacks modernes (Astro, Tailwind CSS, Three.js, TypeScript), intégrons des LLM sur mesure et des agents IA génératifs dans les flux de travail métier, automatisons les opérations avec des pipelines personnalisés, réalisons des audits de sécurité OWASP et des tests d'intrusion, et optimisons le SEO et les Core Web Vitals. Nos projets phares incluent Exploit AI (orchestration de pentest par IA, -85% de temps d'audit), OT_Shield (système de détection d'intrusion OT/ICS), et des divulgations white-hat. Nous servons des clients internationaux en anglais et en français." : "Flintlock is a Morocco-based (Casablanca) digital studio founded by two engineers — Abdellah ERRAOUI (CTO) and Faris BAHBAH (COO) — specializing in high-performance web development, AI integration, automation, and cybersecurity. We build websites and web applications using modern stacks (Astro, Tailwind CSS, Three.js, TypeScript), integrate custom LLMs and generative AI agents into business workflows, automate operations with custom pipelines, run OWASP security audits and penetration testing, and optimize for SEO and Core Web Vitals. Flagship projects include Exploit AI (AI-pentest orchestration, -85% audit time), OT_Shield (OT/ICS intrusion detection system), and responsible white-hat disclosures. We serve international clients in English and French."}</p>
      <p class="geo-type" data-type="organization">ProfessionalService</p>
      <p class="geo-category">Digital Studio — Web Development, AI Integration, Automation, Cybersecurity</p>
      <p class="geo-location">Casablanca, Morocco (Global clients)</p>
      <p class="geo-services">Web Apps, AI Integration, LLM Customization, Business Automation, SEO/GEO, OWASP Audits, Penetration Testing, OT/ICS Security</p>
      <p class="geo-technology">Astro, Tailwind CSS, Three.js, TypeScript, Cloudflare, Plausible Analytics</p>
    </div>

    <script is:inline>
      (function() {
        var prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (prefersReducedMotion) return;

        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add("revealed");
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: "0px 0px -40px 0px" });

        document.addEventListener("DOMContentLoaded", function() {
          document.querySelectorAll(".reveal, .reveal-stagger, .gradient-connector").forEach(function(el) {
            observer.observe(el);
          });
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    padding: 0.5rem 1rem;
    background: var(--color-cyan);
    color: var(--color-onyx);
    font-weight: 700;
    font-size: 0.875rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: top 150ms ease;
  }
  .skip-link:focus {
    top: 1rem;
  }
  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    width: 100%;
  }
  main {
    flex: 1;
    width: 100%;
  }
  .geo-content {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
