---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../sections/Header.astro";
import Footer from "../../sections/Footer.astro";
import { Icon } from "astro-icon/components";
---

<BaseLayout
  lang="fr"
  title="Page introuvable (404) — Studio Flintlock"
  description="La page que vous cherchez n'existe pas. Retournez a l'accueil de Flintlock pour decouvrir nos services en developpement web, IA, automatisation et cybersecurite."
  noindex={true}
>
  <Header slot="header" lang="fr" />

  <section class="min-h-[70vh] flex flex-col items-center justify-center text-center px-[var(--margin-mobile)] md:px-[var(--margin-desktop)]">
    <div class="max-w-lg">
      <span class="block font-mono text-8xl md:text-9xl font-bold text-[var(--color-accent)]/20 tracking-tight">404</span>
      <h1 class="font-display text-2xl md:text-4xl font-bold text-[var(--color-text-primary)] mt-2 mb-4">
        Page introuvable
      </h1>
      <p class="text-base md:text-lg text-[var(--color-text-secondary)] leading-relaxed mb-8">
        La page que vous cherchez n'existe pas ou a ete deplacee.<br/>
        Laissez-nous vous remettre sur la bonne voie.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/fr/" class="cta-forge inline-flex items-center gap-2 px-8 py-4 rounded-[var(--radius-md)] text-black font-bold text-sm uppercase tracking-widest no-underline transition-all duration-300">
          <Icon name="lucide:arrow-left" class="w-4 h-4" />
          Retour a l'accueil
        </a>
        <a href="/fr/#contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-[var(--radius-md)] border text-sm uppercase tracking-widest no-underline transition-all duration-300 hover:border-[var(--color-accent)] hover:text-[var(--color-accent])" style="border-color: var(--color-slate); color: var(--color-text-primary);">
          Nous contacter
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" lang="fr" />
</BaseLayout>
