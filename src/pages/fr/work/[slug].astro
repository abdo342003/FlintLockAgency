---
import WorkLayout from "../../../layouts/WorkLayout.astro";
import { projects } from "../../../data/projects";
import { useTranslations } from "../../../i18n/util";

export async function getStaticPaths() {
  const conceptDemos = projects.filter((p) => p.conceptDemo);
  return conceptDemos.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const t = useTranslations("fr");

const isConcept = project.conceptDemo;
const slugStr = project.slug;
const tagLabel = project.tag.fr;
const title = project.title.fr;
const subtitle = project.subtitle.fr;
const category = project.category.toUpperCase();
---

<WorkLayout lang="fr" title={title} description={project.description.fr} projectSlug={slugStr}>
  <section slot="hero">
    <div class="reveal max-w-3xl">
      <div class="flex items-center gap-3 mb-4">
        <span class="tag-badge">{category}</span>
        {isConcept && <span class="tag-badge tag-badge-cyan">{tagLabel}</span>}
      </div>
      <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-[var(--color-text-primary)] leading-tight mb-4">{title}</h1>
      <p class="text-lg md:text-xl text-[var(--color-text-secondary)] leading-relaxed mb-6">{subtitle}</p>
    </div>
  </section>

  <section slot="content">
    <!-- Challenge -->
    <div class="mb-16 reveal">
      <h2 class="section-title mb-6">{t("portfolio.detail.challenge")}</h2>
      <p class="text-base md:text-lg text-[var(--color-text-secondary)] leading-relaxed max-w-3xl">{project.challenge.fr}</p>
    </div>

    <!-- Approach -->
    <div class="mb-16 reveal">
      <h2 class="section-title mb-6">{t("work.approach")}</h2>
      <p class="text-base md:text-lg text-[var(--color-text-secondary)] leading-relaxed max-w-3xl">{project.solution.fr}</p>
    </div>

    <!-- What We'd Deliver -->
    {project.features && (
      <div class="mb-16 reveal">
        <h2 class="section-title mb-8">{t("work.deliver")}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {project.features.fr.map((feature, i) => (
            <div class="flex items-start gap-3 rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface-2)] p-4" style={`transition-delay: ${0.05 * i}s`}>
              <svg class="w-5 h-5 mt-0.5 flex-shrink-0 text-[var(--color-accent)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
              <span class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{feature}</span>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Tech Stack -->
    <div class="mb-16 reveal">
      <h2 class="section-title mb-6">{t("portfolio.detail.tech")}</h2>
      <div class="flex flex-wrap gap-2">
        {project.techStack.map((tech) => (
          <span class="font-mono text-[11px] px-3 py-1.5 rounded-full border border-[var(--color-border)] bg-[var(--color-surface-2)] text-[var(--color-text-secondary)] tracking-wide">{tech}</span>
        ))}
      </div>
    </div>

    <!-- Potential Impact -->
    <div class="mb-8 reveal">
      <h2 class="section-title mb-6">{t("work.impact")}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-[var(--gutter)]">
        {project.results.map((r, i) => (
          <div class="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-2)] p-6 text-center" style={`transition-delay: ${0.08 * i}s`}>
            <span class="font-display text-2xl md:text-3xl font-bold text-[var(--color-accent)] block mb-2">{r.metric}</span>
            <span class="text-sm text-[var(--color-text-secondary)]">{r.label.fr}</span>
          </div>
        ))}
      </div>
    </div>
  </section>
</WorkLayout>

<style is:global>
  .section-title {
    font-family: var(--font-display, "Instrument Serif", serif);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1.2;
  }
  @media (min-width: 768px) {
    .section-title { font-size: 2rem; }
  }
</style>
