---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ForgeBackground from "../../components/ForgeBackground.astro";
import Cursor from "../../components/Cursor.astro";

import Header from "../../sections/Header.astro";
import Hero from "../../sections/Hero.astro";
import Problem from "../../sections/Problem.astro";
import Solution from "../../sections/Solution.astro";
import Services from "../../sections/Services.astro";
import Process from "../../sections/Process.astro";
import Proof from "../../sections/Proof.astro";
import Stats from "../../sections/Stats.astro";
import Why from "../../sections/Why.astro";
import Team from "../../sections/Team.astro";
import FAQ from "../../sections/FAQ.astro";
import CTA from "../../sections/CTA.astro";
import LeadMagnet from "../../sections/LeadMagnet.astro";
import Footer from "../../sections/Footer.astro";
import { useTranslations } from "../../i18n/util";

const t = useTranslations("fr");
const siteUrl = "https://flintlockagency.com";

const faqEntries = ["1", "2", "3", "4", "5"].map((id) => ({
  "@type": "Question",
  name: t(`faq.${id}.q`),
  acceptedAnswer: {
    "@type": "Answer",
    text: t(`faq.${id}.a`),
  },
}));

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ProfessionalService",
      "@id": `${siteUrl}/#organization`,
      name: "Flintlock",
      url: siteUrl,
      logo: `${siteUrl}/logo.png`,
      image: `${siteUrl}/img/og-image.svg`,
      description:
        "Studio digital : développement web, intégration IA, automatisation et cybersécurité. Construit par deux ingénieurs. Basé au Maroc, clients dans le monde.",
      foundingDate: "2025",
      founders: [
        {
          "@type": "Person",
          "@id": `${siteUrl}/#abdellah-erroui`,
          name: "Abdellah ERRAOUI",
          jobTitle: "CTO & Fondateur",
          url: `${siteUrl}/team#abdellah`,
          sameAs: ["https://www.linkedin.com/in/abdellah-erraoui/"],
          knowsAbout: ["Cybersécurité", "Intelligence Artificielle", "Développement Web", "Sécurité OT/ICS", "Tests d'Intrusion", "OWASP"],
          worksFor: { "@id": `${siteUrl}/#organization` },
        },
        {
          "@type": "Person",
          "@id": `${siteUrl}/#faris-bahbah`,
          name: "Faris BAHBAH",
          jobTitle: "COO & Fondateur",
          url: `${siteUrl}/team#faris`,
          sameAs: ["https://www.linkedin.com/in/faris-bahbah/"],
          knowsAbout: ["Automatisation Métier", "Génération de Leads", "Stratégie Produit", "SEO", "GEO"],
          worksFor: { "@id": `${siteUrl}/#organization` },
        },
      ],
      address: {
        "@type": "PostalAddress",
        addressLocality: "Casablanca",
        addressRegion: "Casablanca-Settat",
        addressCountry: "MA",
      },
      geo: {
        "@type": "GeoCoordinates",
        latitude: 33.5731,
        longitude: -7.5898,
      },
      contactPoint: {
        "@type": "ContactPoint",
        telephone: "+212-706-570686",
        email: "contact@flintlockagency.com",
        contactType: "sales",
        availableLanguage: ["English", "French"],
      },
      sameAs: [
        "https://www.linkedin.com/company/flint-lock/",
        "https://www.instagram.com/flint___lock/",
      ],
      knowsAbout: [
        "Développement Web",
        "Intelligence Artificielle",
        "Apprentissage Automatique",
        "Grands Modèles de Langage",
        "Automatisation",
        "Cybersécurité",
        "SEO",
        "GEO",
        "Tests d'Intrusion",
        "OWASP",
        "Sécurité OT/ICS",
        "Framework Astro",
        "Tailwind CSS",
        "Three.js",
      ],
      areaServed: {
        "@type": "Place",
        name: "International",
      },
      hasOfferCatalog: {
        "@type": "OfferCatalog",
        name: "Services Flintlock",
        itemListElement: [
          {
            "@type": "OfferCatalog",
            name: "Web & Applications",
            itemListElement: [
              {
                "@type": "Offer",
                itemOffered: {
                  "@type": "Service",
                  name: "Développement Web Haute Performance",
                  description: "Sites et applications web sur mesure avec Astro, Tailwind CSS, Three.js. Conforme aux Core Web Vitals, scores Lighthouse optimaux.",
                },
              },
            ],
          },
          {
            "@type": "OfferCatalog",
            name: "Intégration IA",
            itemListElement: [
              {
                "@type": "Offer",
                itemOffered: {
                  "@type": "Service",
                  name: "Intégration LLM & Agents IA Sur Mesure",
                  description: "LLM sur mesure et agents IA génératifs intégrés aux flux de travail métier. Pipelines RAG, automatisation de contenu, analytique prédictive.",
                },
              },
            ],
          },
          {
            "@type": "OfferCatalog",
            name: "Automatisation",
            itemListElement: [
              {
                "@type": "Offer",
                itemOffered: {
                  "@type": "Service",
                  name: "Automatisation des Processus Métier",
                  description: "Pipelines d'automatisation sur mesure. Intégrations API, flux de données, automatisation de workflows.",
                },
              },
            ],
          },
          {
            "@type": "OfferCatalog",
            name: "Acquisition & Leads",
            itemListElement: [
              {
                "@type": "Offer",
                itemOffered: {
                  "@type": "Service",
                  name: "SEO & Génération de Leads",
                  description: "SEO technique, GEO (Optimisation pour les Moteurs IA), stratégie de contenu, optimisation de conversion. Des sites qui rankent et convertissent.",
                },
              },
            ],
          },
          {
            "@type": "OfferCatalog",
            name: "Sécurité",
            itemListElement: [
              {
                "@type": "Offer",
                itemOffered: {
                  "@type": "Service",
                  name: "Cybersécurité & Tests d'Intrusion",
                  description: "Audits OWASP, durcissement d'infrastructure, tests d'intrusion, sécurité OT/ICS. Intégrée dès la première ligne de code.",
                },
              },
            ],
          },
        ],
      },
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      name: "Flintlock",
      url: siteUrl,
      description:
        "Studio digital : web, IA, automatisation, sécurité — construit par deux ingénieurs.",
      inLanguage: "fr",
      publisher: { "@id": `${siteUrl}/#organization` },
      potentialAction: {
        "@type": "SearchAction",
        target: {
          "@type": "EntryPoint",
          urlTemplate: `${siteUrl}/fr/?q={search_term_string}`,
        },
        "query-input": "required name=search_term_string",
      },
    },
    {
      "@type": "WebPage",
      "@id": `${siteUrl}/fr/#webpage`,
      url: `${siteUrl}/fr/`,
      name: "Flintlock — Studio Web, IA, Automatisation & Cybersécurité",
      description:
        "Studio digital au Maroc : développement web haute performance, intégration d'IA, automatisation et cybersécurité. Deux ingénieurs, un partenaire.",
      inLanguage: "fr",
      isPartOf: { "@id": `${siteUrl}/#website` },
      about: { "@id": `${siteUrl}/#organization` },
      mainEntity: { "@id": `${siteUrl}/#organization` },
      datePublished: "2025-01-01T00:00:00Z",
      dateModified: "2026-07-17T12:00:00Z",
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Accueil", item: siteUrl + "/fr/" },
      ],
    },
    {
      "@type": "HowTo",
      name: "Comment Flintlock fonctionne",
      description: "Notre processus en quatre étapes pour mener votre projet du diagnostic au lancement.",
      step: [
        {
          "@type": "HowToStep",
          position: 1,
          name: "Diagnostic & Audit",
          text: "Nous étudions votre activité, auditions votre stack et définissons la feuille de route.",
        },
        {
          "@type": "HowToStep",
          position: 2,
          name: "Conception & Construction",
          text: "Nous concevons l'expérience et la construisons avec performance et accessibilité intégrées.",
        },
        {
          "@type": "HowToStep",
          position: 3,
          name: "Automatisation & IA",
          text: "Nous intégrons l'automatisation et l'IA dans votre flux de travail pour qu'il tourne sans vous.",
        },
        {
          "@type": "HowToStep",
          position: 4,
          name: "Sécurisation, Lancement & Croissance",
          text: "Durcissement, lancement, monitoring. Puis nous itérons pour vous garder en avance.",
        },
      ],
    },
    {
      "@type": "ItemList",
      name: "Services Flintlock",
      description: "Cinq stations de service clés pour la réussite numérique.",
      itemListElement: [
        {
          "@type": "Service",
          position: 1,
          name: "Web & Applications",
          description: "Plateformes numériques haute performance construites avec des stacks modernes. Rapides, animées, optimisées pour la conversion.",
          provider: { "@id": `${siteUrl}/#organization` },
        },
        {
          "@type": "Service",
          position: 2,
          name: "Intégration IA",
          description: "LLM sur mesure et agents génératifs intégrés à votre workflow. Pas un chatbot — un vrai multiplicateur de productivité.",
          provider: { "@id": `${siteUrl}/#organization` },
        },
        {
          "@type": "Service",
          position: 3,
          name: "Automatisation",
          description: "Éliminez les tâches répétitives. Des pipelines sur mesure qui font tourner vos opérations en pilotage automatique.",
          provider: { "@id": `${siteUrl}/#organization` },
        },
        {
          "@type": "Service",
          position: 4,
          name: "Acquisition & Leads",
          description: "Architecture optimisée SEO + génération de leads data-driven. Un trafic qui convertit.",
          provider: { "@id": `${siteUrl}/#organization` },
        },
        {
          "@type": "Service",
          position: 5,
          name: "Sécurité",
          description: "Intégrée par défaut. Audits OWASP, durcissement, expertise OT. Chaque ligne de code protégée.",
          provider: { "@id": `${siteUrl}/#organization` },
        },
      ],
    },
    {
      "@type": "FAQPage",
      mainEntity: faqEntries,
    },
    {
      "@type": "LocalBusiness",
      "@id": `${siteUrl}/#localbusiness`,
      name: "Flintlock",
      image: `${siteUrl}/img/og-image.png`,
      url: siteUrl,
      telephone: "+212-706-570686",
      email: "contact@flintlockagency.com",
      address: {
        "@type": "PostalAddress",
        streetAddress: "Casablanca",
        addressLocality: "Casablanca",
        addressRegion: "Casablanca-Settat",
        postalCode: "20000",
        addressCountry: "MA",
      },
      geo: {
        "@type": "GeoCoordinates",
        latitude: 33.5731,
        longitude: -7.5898,
      },
      openingHoursSpecification: {
        "@type": "OpeningHoursSpecification",
        dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        opens: "09:00",
        closes: "18:00",
      },
      priceRange: "$$",
      areaServed: { "@type": "Place", name: "Worldwide" },
    },
    {
      "@type": "AggregateRating",
      "@id": `${siteUrl}/#rating`,
      itemReviewed: { "@id": `${siteUrl}/#organization` },
      ratingValue: "5.0",
      bestRating: "5",
      reviewCount: "12",
      ratingCount: "12",
    },
    {
      "@type": "Speakable",
      "@id": `${siteUrl}/#speakable`,
      cssSelector: ["h1", ".geo-description"],
    },
    {
      "@type": "Dataset",
      name: "NexGsec AI — Métriques de Performance d'Orchestration de Pentest IA",
      description: "Données de benchmark de NexGsec AI : plateforme d'orchestration automatisée de tests de pénétration. Mesure la réduction du temps d'audit, l'efficacité coût et la couverture de détection des vulnérabilités.",
      url: `${siteUrl}/fr`,
      creator: { "@id": `${siteUrl}/#organization` },
      about: [
        { "@type": "Thing", name: "Tests de Pénétration" },
        { "@type": "Thing", name: "Intelligence Artificielle" },
        { "@type": "Thing", name: "Cybersécurité" },
      ],
      variableMeasured: [
        { "@type": "PropertyValue", name: "Réduction du Temps d'Audit", unitText: "pourcentage", value: "85" },
        { "@type": "PropertyValue", name: "Durée d'Audit (Avant)", unitText: "jours", value: "45" },
        { "@type": "PropertyValue", name: "Durée d'Audit (Après)", unitText: "jours", value: "7" },
      ],
      temporalCoverage: "2025/2026",
      license: "https://flintlockagency.com",
    },
  ],
};
---

<BaseLayout lang="fr">
  <ForgeBackground slot="background" />
  <Cursor />

  <Header slot="header" lang="fr" />

  <Hero lang="fr" />

  <Problem lang="fr" />
  <Solution lang="fr" />

  <Services lang="fr" />
  <Process lang="fr" />

  <Proof lang="fr" />
  <Stats lang="fr" />
  <Why lang="fr" />
  <Team lang="fr" />

  <FAQ lang="fr" />
  <CTA lang="fr" />
  <LeadMagnet lang="fr" />

  <Footer slot="footer" lang="fr" />

  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
</BaseLayout>
