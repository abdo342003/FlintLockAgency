---
import ServiceLayout from "../../layouts/ServiceLayout.astro";
import { services } from "../../data/services";
import { projects } from "../../data/projects";
import { useTranslations } from "../../i18n/util";

export async function getStaticPaths() {
  return services.map((s) => ({
    params: { slug: s.slug },
    props: { service: s },
  }));
}

interface Props {
  service: typeof services[number];
}

const { service } = Astro.props;
const t = useTranslations("en");
const relatedProjects = projects.filter((p) => p.relatedService === service.slug);
---

<ServiceLayout lang="en" title={t(`service.${service.slug}.page.title`)} description={t(`service.${service.slug}.page.desc`)} serviceSlug={service.slug}>
  {
    relatedProjects.length > 0 && (
      <section class="py-[var(--stack-lg)] px-[var(--margin-mobile)] md:px-[var(--margin-desktop)] relative bg-surface section-glow-cyan">
        <div class="mx-auto" style="max-width: var(--container-max);">
          <div class="reveal mb-12">
            <p class="section-kicker">{service.station}</p>
            <h2 class="section-title">{t(`service.${service.slug}.page.case.title`)}</h2>
            <p class="text-base md:text-lg text-[var(--color-text-secondary)] max-w-2xl mt-4">{t(`service.${service.slug}.page.case.desc`)}</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-[var(--gutter)]">
            {relatedProjects.slice(0, 2).map((p, i) => (
              <a href={`/portfolio/#${p.slug}`} class="service-case-card group" style={`transition-delay: ${0.08 * i}s`}>
                <div class="flex items-center gap-4 mb-4">
                  <div class="w-12 h-12 rounded-[var(--radius-md)] bg-[var(--color-surface-1)] flex items-center justify-center overflow-hidden border border-[var(--color-border)] flex-shrink-0">
                    <img src={p.logo} alt={p.title.en} class="w-8 h-8 object-contain" loading="lazy" />
                  </div>
                  <div>
                    <span class="tag-badge" style={`border-color: ${p.color}33; color: ${p.color};`}>{p.tag.en}</span>
                    <h3 class="font-bold text-base text-[var(--color-text-primary)] mt-1">{p.title.en}</h3>
                  </div>
                </div>
                <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4">{p.description.en}</p>
                <div class="flex flex-wrap gap-2 mb-4">
                  {p.techStack.slice(0, 3).map((tech) => (
                    <span class="font-mono text-[10px] px-2 py-1 rounded-full bg-[var(--color-surface-1)] text-[var(--color-text-secondary)]/60 border border-[var(--color-border)]">{tech}</span>
                  ))}
                </div>
                <span class="text-xs text-[var(--color-accent)] font-mono tracking-wider uppercase group-hover:underline">
                  {t("portfolio.detail.view")} →
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }
</ServiceLayout>
