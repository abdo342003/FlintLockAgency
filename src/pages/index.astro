---
import BaseLayout from "../layouts/BaseLayout.astro";
import ForgeBackground from "../components/ForgeBackground.astro";
import Cursor from "../components/Cursor.astro";

import Header from "../sections/Header.astro";
import Hero from "../sections/Hero.astro";
import Problem from "../sections/Problem.astro";
import Solution from "../sections/Solution.astro";
import Services from "../sections/Services.astro";
import Process from "../sections/Process.astro";
import Proof from "../sections/Proof.astro";
import Stats from "../sections/Stats.astro";
import Why from "../sections/Why.astro";
import Team from "../sections/Team.astro";
import FAQ from "../sections/FAQ.astro";
import CTA from "../sections/CTA.astro";
import LeadMagnet from "../sections/LeadMagnet.astro";
import Footer from "../sections/Footer.astro";
import CalendlyModal from "../components/CalendlyModal.astro";
import { useTranslations } from "../i18n/util";

const t = useTranslations("en");
const siteUrl = "https://flintlockagency.com";

const faqEntries = ["1", "2", "3", "4", "5"].map((id) => ({
  "@type": "Question",
  name: t(`faq.${id}.q`),
  acceptedAnswer: {
    "@type": "Answer",
    text: t(`faq.${id}.a`),
  },
}));

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ProfessionalService",
      "@id": `${siteUrl}/#organization`,
      name: "Flintlock",
      url: siteUrl,
      logo: `${siteUrl}/logo.png`,
      image: `${siteUrl}/img/og-image.svg`,
      description:
        "Digital studio: web development, AI integration, automation, and cybersecurity. Built by two engineers. Based in Morocco, global clients.",
      foundingDate: "2025",
      founders: [
        { "@type": "Person", name: "Abdellah ERRAOUI", jobTitle: "CTO & Founder" },
        { "@type": "Person", name: "Faris BAHBAH", jobTitle: "COO & Founder" },
      ],
      address: {
        "@type": "PostalAddress",
        addressLocality: "Casablanca",
        addressRegion: "Casablanca-Settat",
        addressCountry: "MA",
      },
      geo: {
        "@type": "GeoCoordinates",
        latitude: 33.5731,
        longitude: -7.5898,
      },
      contactPoint: {
        "@type": "ContactPoint",
        telephone: "+212-706-570686",
        email: "contact@flintlockagency.com",
        contactType: "sales",
        availableLanguage: ["English", "French"],
      },
      sameAs: [
        "https://www.linkedin.com/company/flint-lock/",
        "https://www.instagram.com/flint___lock/",
        "https://github.com/flintlock",
      ],
      knowsAbout: [
        "Web Development",
        "Artificial Intelligence",
        "Machine Learning",
        "Large Language Models",
        "Automation",
        "Cybersecurity",
        "SEO",
        "GEO",
        "Penetration Testing",
        "OWASP",
        "OT/ICS Security",
        "Astro Framework",
        "Tailwind CSS",
        "Three.js",
      ],
      areaServed: {
        "@type": "Place",
        name: "Worldwide",
      },
      hasOfferCatalog: {
        "@type": "OfferCatalog",
        name: "Flintlock Services",
        itemListElement: [
          {
            "@type": "OfferCatalog",
            name: "Web & Apps",
            itemListElement: [
              {
                "@type": "Offer",
                itemOffered: {
                  "@type": "Service",
                  name: "High-Performance Web Development",
                  description: "Custom websites and web apps built with Astro, Tailwind CSS, Three.js. Core Web Vitals compliant, top Lighthouse scores.",
                },
              },
            ],
          },
          {
            "@type": "OfferCatalog",
            name: "AI Integration",
            itemListElement: [
              {
                "@type": "Offer",
                itemOffered: {
                  "@type": "Service",
                  name: "Custom LLM & AI Agent Integration",
                  description: "Custom LLMs and generative AI agents embedded into business workflows. RAG pipelines, content automation, predictive analytics.",
                },
              },
            ],
          },
          {
            "@type": "OfferCatalog",
            name: "Automation",
            itemListElement: [
              {
                "@type": "Offer",
                itemOffered: {
                  "@type": "Service",
                  name: "Business Process Automation",
                  description: "Custom automation pipelines for operations on autopilot. API integrations, data pipelines, workflow automation.",
                },
              },
            ],
          },
          {
            "@type": "OfferCatalog",
            name: "Acquisition & Leads",
            itemListElement: [
              {
                "@type": "Offer",
                itemOffered: {
                  "@type": "Service",
                  name: "SEO & Lead Generation",
                  description: "Technical SEO, GEO (Generative Engine Optimisation), content strategy, conversion optimisation. Sites that rank and convert.",
                },
              },
            ],
          },
          {
            "@type": "OfferCatalog",
            name: "Security",
            itemListElement: [
              {
                "@type": "Offer",
                itemOffered: {
                  "@type": "Service",
                  name: "Cybersecurity & Penetration Testing",
                  description: "OWASP audits, infrastructure hardening, penetration testing, OT/ICS security. Built in from the first line of code.",
                },
              },
            ],
          },
        ],
      },
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      name: "Flintlock",
      url: siteUrl,
      description:
        "Digital studio: web, AI, automation, security — built by two engineers.",
      inLanguage: "en",
      publisher: { "@id": `${siteUrl}/#organization` },
      potentialAction: {
        "@type": "SearchAction",
        target: {
          "@type": "EntryPoint",
          urlTemplate: `${siteUrl}/?q={search_term_string}`,
        },
        "query-input": "required name=search_term_string",
      },
    },
    {
      "@type": "WebPage",
      "@id": `${siteUrl}/#webpage`,
      url: siteUrl,
      name: "Flintlock — Web Development, AI Automation & Cybersecurity Studio",
      description:
        "Morocco-based digital studio: high-performance web development, AI integration, automation & cybersecurity. Two engineers, one partner.",
      inLanguage: "en",
      isPartOf: { "@id": `${siteUrl}/#website` },
      about: { "@id": `${siteUrl}/#organization` },
      mainEntity: { "@id": `${siteUrl}/#organization` },
      datePublished: "2025-01-01T00:00:00Z",
      dateModified: "2026-07-17T12:00:00Z",
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
      ],
    },
    {
      "@type": "HowTo",
      name: "How Flintlock Works",
      description: "Our four-step process to take your project from discovery to launch.",
      step: [
        {
          "@type": "HowToStep",
          position: 1,
          name: "Discovery & Audit",
          text: "We learn your business, audit your current stack, and define the roadmap.",
        },
        {
          "@type": "HowToStep",
          position: 2,
          name: "Design & Build",
          text: "We craft the experience and build it with performance and accessibility baked in.",
        },
        {
          "@type": "HowToStep",
          position: 3,
          name: "Automate & Integrate AI",
          text: "We wire automation and AI into your workflow so it runs without you.",
        },
        {
          "@type": "HowToStep",
          position: 4,
          name: "Secure, Launch & Grow",
          text: "Hardening, launch, monitoring. Then we iterate to keep you ahead.",
        },
      ],
    },
    {
      "@type": "ItemList",
      name: "Flintlock Services",
      description: "Five core service stations for digital success.",
      itemListElement: [
        {
          "@type": "Service",
          position: 1,
          name: "Web & Apps",
          description: "High-performance digital platforms built with modern stacks. Fast, animated, conversion-optimised.",
          provider: { "@id": `${siteUrl}/#organization` },
        },
        {
          "@type": "Service",
          position: 2,
          name: "AI Integration",
          description: "Custom LLMs and generative agents embedded into your workflow. Not a chatbot — a real productivity multiplier.",
          provider: { "@id": `${siteUrl}/#organization` },
        },
        {
          "@type": "Service",
          position: 3,
          name: "Automation",
          description: "Eliminate repetitive tasks. Custom pipelines that run your operations on autopilot.",
          provider: { "@id": `${siteUrl}/#organization` },
        },
        {
          "@type": "Service",
          position: 4,
          name: "Acquisition & Leads",
          description: "SEO-optimised architecture + data-driven lead generation. Traffic that converts.",
          provider: { "@id": `${siteUrl}/#organization` },
        },
        {
          "@type": "Service",
          position: 5,
          name: "Security",
          description: "Built in by default. OWASP audits, hardening, OT expertise. Every line of code protected.",
          provider: { "@id": `${siteUrl}/#organization` },
        },
      ],
    },
    {
      "@type": "FAQPage",
      mainEntity: faqEntries,
    },
    {
      "@type": "LocalBusiness",
      "@id": `${siteUrl}/#localbusiness`,
      name: "Flintlock",
      image: `${siteUrl}/img/og-image.png`,
      url: siteUrl,
      telephone: "+212-706-570686",
      email: "contact@flintlockagency.com",
      address: {
        "@type": "PostalAddress",
        streetAddress: "Casablanca",
        addressLocality: "Casablanca",
        addressRegion: "Casablanca-Settat",
        postalCode: "20000",
        addressCountry: "MA",
      },
      geo: {
        "@type": "GeoCoordinates",
        latitude: 33.5731,
        longitude: -7.5898,
      },
      openingHoursSpecification: {
        "@type": "OpeningHoursSpecification",
        dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        opens: "09:00",
        closes: "18:00",
      },
      priceRange: "$$",
      areaServed: { "@type": "Place", name: "Worldwide" },
    },
    {
      "@type": "AggregateRating",
      "@id": `${siteUrl}/#rating`,
      itemReviewed: { "@id": `${siteUrl}/#organization` },
      ratingValue: "5.0",
      bestRating: "5",
      reviewCount: "12",
      ratingCount: "12",
    },
  ],
};
---

<BaseLayout lang="en">
  <ForgeBackground slot="background" />
  <Cursor />

  <Header slot="header" lang="en" />

  <Hero lang="en" />

  <Problem lang="en" />
  <Solution lang="en" />

  <Services lang="en" />
  <Process lang="en" />

  <Proof lang="en" />
  <Stats lang="en" />
  <Why lang="en" />
  <Team lang="en" />

  <FAQ lang="en" />
  <CTA lang="en" />
  <LeadMagnet lang="en" />

  <Footer slot="footer" lang="en" />
  <CalendlyModal lang="en" />

  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
</BaseLayout>
